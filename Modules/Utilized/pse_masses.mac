    ["Tl", 204.38, 81],
    ["Pb", 207.20, 82],
    ["Bi", 208.98, 83],
    ["Po", 209, 84],
    ["At", 210, 85],
    ["Rn", 222, 86],
    ["Fr", 223, 87],
    ["Ra", 226, 88],
    ["Ac", 227, 89],
    ["Th", 232.04, 90],
    ["Pa", 231.04, 91],
