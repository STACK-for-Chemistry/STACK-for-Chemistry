/* Returns the atomic number (Z) of an element. */
chem_atomic_number(element) := block([entry],
    entry: assoc(element, %_CHEM_ELEMENT_DATA),
    if is(entry = false) then false else third(entry)
)$

/* Returns the molar mass of an element in g/mol. */
chem_atomic_mass(element) := block([entry],
    entry: assoc(element, %_CHEM_ELEMENT_DATA),
    if is(entry = false) then false else second(entry)
)$

/* Returns the molar mass of an element with units attached. */
chem_atomic_mass_units(element) := block([mass],
    mass: chem_atomic_mass(element),
    if is(mass = false) then false else stackunits(mass, g*mol^(-1))
)$

/* Element-wise alias matching the molecular molar-mass naming. */
chem_molar_mass_element(element) := chem_atomic_mass(element)$

/* Element-wise alias matching the molecular molar-mass naming. */
chem_molar_mass_element_units(element) := chem_atomic_mass_units(element)$

/* Manual digit-to-number conversion without forbidden functions. */
chem_string_to_number(str) := block([chars, result, i, digit_val],
    if sequal(str, "") then return(0),
    chars: charlist(str),
    result: 0,
    for i:1 thru length(chars) do (
        digit_val: cint(chars[i]) - 48,
        result: result * 10 + digit_val
    ),
    result
)$

/* Parses a simple chemical formula into [element, count] pairs.
   Parentheses are not expanded here; repeated elements are summed in chem_molar_mass. */
chem_parse_formula(formula) := block([chars, i, n, result, current_element, current_count, num_val],
    chars: charlist(formula),
    n: length(chars),
    i: 1,
    result: [],

    while i <= n do (
        if cgreaterp(chars[i], "@") and clessp(chars[i], "[") then (
            current_element: chars[i],
            i: i + 1,

            if i <= n and cgreaterp(chars[i], "`") and clessp(chars[i], "{") then (
                current_element: sconcat(current_element, chars[i]),
                i: i + 1
            ),

            current_count: "",
            while i <= n and cgreaterp(chars[i], "/") and clessp(chars[i], ":") do (
                current_count: sconcat(current_count, chars[i]),
                i: i + 1
            ),

            if sequal(current_count, "") then num_val: 1
            else num_val: chem_string_to_number(current_count),

            result: cons([current_element, num_val], result)
        ) else (
            i: i + 1
        )
    ),

    reverse(result)
)$

/* Calculates the molar mass of a molecule from a formula string.
   Example: chem_molar_mass("H2SO4") returns stackunits(98.09, g*mol^(-1)). */
chem_molar_mass(formula) := block([parsed, total_mass, pair, elem_mass],
    parsed: chem_parse_formula(formula),
    total_mass: 0,

    for pair in parsed do (
        elem_mass: chem_atomic_mass(first(pair)),
        if is(elem_mass = false) then return(false),
        total_mass: total_mass + elem_mass * second(pair)
    ),

    stackunits(total_mass, g*mol^(-1))
)$

/****************************************************************/
/*                                                              */
/*  Chemical Formula Display Function                           */
/*                                                              */
/****************************************************************/

/* This function wraps a chemical formula in \ce{} for LaTeX/mhchem rendering.
   Example: chem_display("H2SO4") returns "\\ce{H2SO4}" */
chem_display(substance) := sconcat("\\ce{", substance, "}")$