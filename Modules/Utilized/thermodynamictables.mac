/* Standard tags for substance classification */
%_TAG_ELEMENT: "element"$
%_TAG_ION: "ion"$
%_TAG_CATION: "cation"$
%_TAG_ANION: "anion"$
%_TAG_MOLECULE: "molecule"$
%_TAG_SALT: "salt"$
