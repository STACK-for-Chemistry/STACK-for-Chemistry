/****************************************************************/
/*                                                              */
/*  Helper Functions                                            */
/*                                                              */
/****************************************************************/

/* Field names for the four numeric columns */
%_THERMO_FIELDS: ["DeltaHf", "S", "DeltaGf", "Cp"]$

/* Units for the four numeric columns */
%_THERMO_UNITS: [kJ*mol^(-1), J*mol^(-1)*K^(-1), kJ*mol^(-1), J*mol^(-1)*K^(-1)]$

/* Build [[field1,v1],[field2,v2],...] from two parallel lists */
chem_thermo_make_pairs(fields, data) := block([result, i],
    result: [],
    for i: 1 thru min(length(fields), length(data)) do
        result: endcons([fields[i], data[i]], result),
    return(result)
)$

/* Remove duplicates from a list (STACK-safe, no unique) */
chem_thermo_unique(lst) := block([result, item],
    result: [],
    for item in lst do (
        if not member(item, result) then
            result: endcons(item, result)
    ),
    return(result)
)$

/* Check if ALL elements of lst satisfy pred (STACK-safe, no every) */
chem_thermo_all_match(pred, lst) := block([result, item],
    result: true,
    for item in lst do (
        if not pred(item) then result: false
    ),
    return(result)
)$

/* Check if ANY element of lst satisfies pred (STACK-safe, no some) */
chem_thermo_any_match(pred, lst) := block([result, item],
    result: false,
    for item in lst do (
        if pred(item) then result: true
    ),
    return(result)
)$

/****************************************************************/
/*                                                              */
/*  Core Data Retrieval                                         */
/*                                                              */
/****************************************************************/

/* Look up the raw state-record [ΔHf, S, ΔGf, Cp, [Tags]] for
   a given substance and state.  Returns false when not found. */
chem_thermo_raw(substance, state) := block([states_list, rec],
    states_list: assoc(substance, %_THERMO_DATA),
    if is(states_list = false) then return(false),
    rec: assoc(state, states_list),
    return(rec)   /* false when state not present */
)$

/* Return all thermodynamic data as an assoc list
   [["DeltaHf",v],["S",v],["DeltaGf",v],["Cp",v],["State",st],["Tags",[...]]] */
chem_thermo_data_all(substance, state) := block([rec],
    rec: chem_thermo_raw(substance, state),
    if is(rec = false) then return(false),
    return(append(
        chem_thermo_make_pairs(%_THERMO_FIELDS, [rec[1], rec[2], rec[3], rec[4]]),
        [["State", state], ["Tags", rec[5]]]
    ))
)$

/* Same but picks the first available state */
chem_thermo_data_all_any(substance) := block([states_list],
    states_list: assoc(substance, %_THERMO_DATA),
    if is(states_list = false) then return(false),
    return(chem_thermo_data_all(substance, first(first(states_list))))
)$

/* Return a single property (string key) for a substance + state */
chem_thermo_data(substance, property, state) :=
    assoc(property, chem_thermo_data_all(substance, state))$

/* Return a single property with STACK units attached */
chem_thermo_data_units(substance, property, state) := block([val, unit],
    val: chem_thermo_data(substance, property, state),
    if is(val = false) or is(val = null) then return(false),
    unit: assoc(property, chem_thermo_make_pairs(%_THERMO_FIELDS, %_THERMO_UNITS)),
    if is(unit = false) or is(unit = null) then return(val)
    else return(stackunits(val, unit))
)$

/****************************************************************/
/*                                                              */
/*  Reaction Thermodynamics                                     */
/*                                                              */
/****************************************************************/

/* ΔH° = Σ ν·ΔHf°(products) − Σ ν·ΔHf°(reactants) */
chem_reaction_enthalpy(products_list, reactants_list) := block([sum_prod, sum_react],
    sum_prod: 0,
    sum_react: 0,
    for item in products_list do
        sum_prod: sum_prod + third(item) * chem_thermo_data(first(item), "DeltaHf", second(item)),
    for item in reactants_list do
        sum_react: sum_react + third(item) * chem_thermo_data(first(item), "DeltaHf", second(item)),
    delta_h: sum_prod - sum_react;
    return(stackunits(delta_h, kJ*mol^(-1)))
)$

/* ΔS° */
chem_reaction_entropy(products_list, reactants_list) := block([sum_prod, sum_react],
    sum_prod: 0,
    sum_react: 0,
    for item in products_list do
        sum_prod: sum_prod + third(item) * chem_thermo_data(first(item), "S", second(item)),
    for item in reactants_list do
        sum_react: sum_react + third(item) * chem_thermo_data(first(item), "S", second(item)),
    delta_s: sum_prod - sum_react;
    return(stackunits(delta_s, J*mol^(-1)*K^(-1))
)$

/* ΔG° with units */
chem_reaction_gibbs(products_list, reactants_list) := block([sum_prod, sum_react, delta_g],
    sum_prod: 0,
    sum_react: 0,
    for item in products_list do
        sum_prod: sum_prod + third(item) * chem_thermo_data(first(item), "DeltaGf", second(item)),
    for item in reactants_list do
        sum_react: sum_react + third(item) * chem_thermo_data(first(item), "DeltaGf", second(item)),
    delta_g: sum_prod - sum_react,
    return(stackunits(delta_g, kJ*mol^(-1)))
)$

/* ΔG = ΔH − TΔS  (ΔH in kJ, ΔS in J, result in kJ) */
chem_gibbs_from_enthalpy_entropy(delta_h, delta_s, temp) := block([delta_g],
    delta_g: delta_h - temp * delta_s / 1000,
    return(stackunits(delta_g, kJ*mol^(-1)))
)$

/* K = exp(−ΔG°/RT)  (ΔG in kJ, R in J) */
chem_equilibrium_constant(delta_g, temp) := block([R],
    R: 8.314,
    return(%e^(-delta_g * 1000 / (R * temp)))
)$

/****************************************************************/
/*                                                              */
/*  Reaction-name wrappers (need reactions.mac loaded)          */
/*                                                              */
/****************************************************************/

chem_reaction_enthalpy_by_name(reaction_name) := block([reactants, products],
    reactants: chem_reaction_reactants(reaction_name),
    products:  chem_reaction_products(reaction_name),
    if is(reactants = false) or is(products = false) then return(false),
    return(chem_reaction_enthalpy(products, reactants))
)$

chem_reaction_entropy_by_name(reaction_name) := block([reactants, products],
    reactants: chem_reaction_reactants(reaction_name),
    products:  chem_reaction_products(reaction_name),
    if is(reactants = false) or is(products = false) then return(false),
    return(chem_reaction_entropy(products, reactants))
)$

chem_reaction_gibbs_by_name(reaction_name) := block([reactants, products],
    reactants: chem_reaction_reactants(reaction_name),
    products:  chem_reaction_products(reaction_name),
    if is(reactants = false) or is(products = false) then return(false),
    return(chem_reaction_gibbs(products, reactants))
)$

/****************************************************************/
/*                                                              */
/*  Navigation Functions                                        */
/*                                                              */
/****************************************************************/

/* All distinct substance formulas */
chem_thermo_substance_array() :=
    map(first, %_THERMO_DATA)$

/* All substance formulas that have data for a given state */
chem_thermo_substance_state_array(state) := block([result],
    result: [],
    for entry in %_THERMO_DATA do (
        if not is(assoc(state, second(entry)) = false) then
            result: endcons(first(entry), result)
    ),
    return(result)
)$

/* List of states available for a substance */
chem_thermo_states(substance) := block([states_list],
    states_list: assoc(substance, %_THERMO_DATA),
    if is(states_list = false) then return(false),
    return(map(first, states_list))
)$

/****************************************************************/
/*                                                              */
/*  Tag-Based Filtering                                         */
/*                                                              */
/****************************************************************/

/* Internal: flatten to a list of [formula, state, [ΔH,S,ΔG,Cp,[Tags]]] */
chem_thermo_flat_entries() := block([result],
    result: [],
    for entry in %_THERMO_DATA do
        for srec in second(entry) do
            result: endcons([first(entry), first(srec), second(srec)], result),
    return(result)
)$

/* Does a flat entry [formula, state, rec] carry a given tag? */
chem_thermo_flat_has_tag(fentry, tag) := block([tags],
    tags: fifth(third(fentry)),
    if listp(tags) then member(tag, tags) else false
)$

/* All flat entries with a specific tag */
chem_thermo_filter_by_tag(tag) :=
    sublist(chem_thermo_flat_entries(), lambda([x], chem_thermo_flat_has_tag(x, tag)))$

/* All flat entries with ALL specified tags */
chem_thermo_filter_by_tags_all(tag_list) :=
    sublist(chem_thermo_flat_entries(), lambda([x],
        block([tags],
            tags: fifth(third(x)),
            if listp(tags) then
                chem_thermo_all_match(lambda([t], member(t, tags)), tag_list)
            else false
        )))$

/* All flat entries with ANY of the specified tags */
chem_thermo_filter_by_tags_any(tag_list) :=
    sublist(chem_thermo_flat_entries(), lambda([x],
        block([tags],
            tags: fifth(third(x)),
            if listp(tags) then
                chem_thermo_any_match(lambda([t], member(t, tags)), tag_list)
            else false
        )))$

/* Distinct formulas carrying a specific tag */
chem_thermo_substances_by_tag(tag) :=
    chem_thermo_unique(map(first, chem_thermo_filter_by_tag(tag)))$

/* Distinct formulas carrying ALL specified tags */
chem_thermo_substances_by_tags_all(tag_list) :=
    chem_thermo_unique(map(first, chem_thermo_filter_by_tags_all(tag_list)))$

/* Distinct formulas carrying ANY specified tag */
chem_thermo_substances_by_tags_any(tag_list) :=
    chem_thermo_unique(map(first, chem_thermo_filter_by_tags_any(tag_list)))$

/* Tags for a substance (first state found) */
chem_thermo_get_tags(substance) := block([states_list],
    states_list: assoc(substance, %_THERMO_DATA),
    if is(states_list = false) then return(false),
    return(fifth(second(first(states_list))))
)$

/* Tags for a substance in a specific state */
chem_thermo_get_tags_state(substance, state) := block([rec],
    rec: chem_thermo_raw(substance, state),
    if is(rec = false) then return(false),
    return(fifth(rec))
)$

/* Alias kept for backward compatibility */
chem_thermo_random_by_tags_all(tag_list) :=
    chem_thermo_substances_by_tags_all(tag_list)$

/* Full paired data for entries filtered by tag */
chem_thermo_data_by_tag(tag) := block([filtered],
    filtered: chem_thermo_filter_by_tag(tag),
    map(lambda([x], [first(x), second(x),
        chem_thermo_make_pairs(%_THERMO_FIELDS,
            [third(x)[1], third(x)[2], third(x)[3], third(x)[4]])]),
        filtered)
)$

/* Full paired data for entries filtered by tag AND state */
chem_thermo_data_by_tag_state(tag, state) := block([filtered],
    filtered: sublist(chem_thermo_filter_by_tag(tag),
                lambda([x], sequal(second(x), state))),
    map(lambda([x], [first(x), second(x),
        chem_thermo_make_pairs(%_THERMO_FIELDS,
            [third(x)[1], third(x)[2], third(x)[3], third(x)[4]])]),
        filtered)
)$