/****************************************************************/
/*                                                              */
/*  Thermodynamic Data Retrieval Functions                      */
/*                                                              */
/****************************************************************/

/* Field names for thermodynamic data (phase data) */
%_THERMO_PHASE_FIELDS: ["State", "DeltaHf", "S", "DeltaGf", "Cp"]$

/* Units for thermodynamic data */
%_THERMO_UNITS: [null, kJ*mol^(-1), J*mol^(-1)*K^(-1), kJ*mol^(-1), J*mol^(-1)*K^(-1)]$

/* Helper: Get entry for a substance */two lists (replacement for zip_with) */
_chem_thermo_get_entry(substance) := block([match],,
    match: sublist(%_THERMO_DATA, lambda([x], sequal(first(x), substance))),
    if emptyp(match) then false else first(match)) do (
        result: append(result, [[keys[i], values[i]]])
    ),
    return(result)
)$

/* Helper: Get entry for a substance */
_chem_thermo_get_entry(substance) := block([match],
    match: sublist(%_THERMO_DATA, lambda([x], sequal(first(x), substance))),
    if emptyp(match) then false else first(match)
)$

/* Helper: Get phase data from entry */
_chem_thermo_get_phase_data(entry, state) := block([phases, match],
    if is(entry = false) then return(false),
    phases: third(entry),
    match: sublist(phases, lambda([p], sequal(first(p), state))),
    if emptyp(match) then false else first(match)
)$

/* Returns all thermodynamic data for a substance in a specific state */
chem_thermo_data_all(substance, state) := block([entry, phase_data],
    entry: _chem_thermo_get_entry(substance),
    if is(entry = false) then return(false),
    phase_data: _chem_thermo_get_phase_data(entry, state),
    if is(phase_data = false) then return(false),
    return(_chem_thermo_zip(%_THERMO_PHASE_FIELDS, phase_data))
)$

/* Returns all thermodynamic data for a substance (first phase if multiple exist) */
chem_thermo_data_all_any(substance) := block([entry, phase_data],
    entry: _chem_thermo_get_entry(substance),
    if is(entry = false) then return(false),
    phase_data: first(third(entry)),
    return(_chem_thermo_zip(%_THERMO_PHASE_FIELDS, phase_data))
)$

/* Helper: Get value from key-value pair list */
_chem_thermo_assoc(key, kvlist) := block([match],
    if not(listp(kvlist)) then return(false),
    match: sublist(kvlist, lambda([x], sequal(first(x), key))),
    if emptyp(match) then false else second(first(match))
)$

/* Returns a specific thermodynamic property for a substance in a specific state */
chem_thermo_data(substance, property, state) := 
    _chem_thermo_assoc(property, chem_thermo_data_all(substance, state))$

/* Returns a specific thermodynamic property with units */
chem_thermo_data_units(substance, property, state) := block([value, unit, field_idx],
    value: chem_thermo_data(substance, property, state),
    if is(value = false) or is(value = null) then return(false),
    field_idx: sublist_indices(%_THERMO_PHASE_FIELDS, lambda([f], sequal(f, property))),
    if emptyp(field_idx) then return(false),
    unit: %_THERMO_UNITS[first(field_idx)],
    if is(unit = null) then return(value)
    else return(stackunits(value, unit))
)$

/* Calculate reaction enthalpy: ΔH° = Σ(ΔHf°products) - Σ(ΔHf°reactants) */
chem_reaction_enthalpy(products_list, reactants_list) := block([sum_prod, sum_react],
    /* products_list and reactants_list are lists of [[substance, state, stoich_coeff], ...] */
    sum_prod: 0,
    sum_react: 0,
    
    for item in products_list do (
        sum_prod: sum_prod + third(item) * chem_thermo_data(first(item), "DeltaHf", second(item))
    ),
    
    for item in reactants_list do (
        sum_react: sum_react + third(item) * chem_thermo_data(first(item), "DeltaHf", second(item))
    ),
    
    return(sum_prod - sum_react)
)$

/* Calculate reaction entropy: ΔS° = Σ(S°products) - Σ(S°reactants) */
chem_reaction_entropy(products_list, reactants_list) := block([sum_prod, sum_react],
    sum_prod: 0,
    sum_react: 0,
    
    for item in products_list do (
        sum_prod: sum_prod + third(item) * chem_thermo_data(first(item), "S", second(item))
    ),
    
    for item in reactants_list do (
        sum_react: sum_react + third(item) * chem_thermo_data(first(item), "S", second(item))
    ),
    
    return(sum_prod - sum_react)
)$

/* Calculate reaction Gibbs free energy: ΔG° = Σ(ΔGf°products) - Σ(ΔGf°reactants) with units */
chem_reaction_gibbs(products_list, reactants_list) := block([sum_prod, sum_react, delta_g],
    sum_prod: 0,
    sum_react: 0,
    
    for item in products_list do (
        sum_prod: sum_prod + third(item) * chem_thermo_data(first(item), "DeltaGf", second(item))
    ),
    
    for item in reactants_list do (
        sum_react: sum_react + third(item) * chem_thermo_data(first(item), "DeltaGf", second(item))
    ),
    
    delta_g: sum_prod - sum_react,
    return(stackunits(delta_g, kJ*mol^(-1)))
)$

/* Calculate ΔG from ΔH and ΔS: ΔG = ΔH - TΔS with units */
chem_gibbs_from_enthalpy_entropy(delta_h, delta_s, temp) := block([delta_g],
    delta_g: delta_h - temp * delta_s / 1000,  /* Convert J to kJ */
    return(stackunits(delta_g, kJ*mol^(-1)))
)$

/* Calculate equilibrium constant from ΔG°: K = exp(-ΔG°/RT) */
chem_equilibrium_constant(delta_g, temp) := block([R],
    R: 8.314,  /* J/(mol·K) */
    return(%e^(-delta_g * 1000 / (R * temp)))  /* Convert kJ to J */
)$

/****************************************************************/
/*                                                              */
/*  Reaction-Based Thermodynamic Calculations                   */
/*  (Requires reactions.mac to be loaded)                       */
/*                                                              */
/****************************************************************/

/* Calculate ΔH° for a reaction by name */
chem_reaction_enthalpy_by_name(reaction_name) := block([reactants, products],
    if not(fboundp('chem_reaction_reactants)) then
        return(false),
    reactants: chem_reaction_reactants(reaction_name),
    products: chem_reaction_products(reaction_name),
    
    if is(reactants = false) or is(products = false) then return(false),
    
    return(chem_reaction_enthalpy(products, reactants))
)$

/* Calculate ΔS° for a reaction by name */
chem_reaction_entropy_by_name(reaction_name) := block([reactants, products],
    if not(fboundp('chem_reaction_reactants)) then
        return(false),
    reactants: chem_reaction_reactants(reaction_name),
    products: chem_reaction_products(reaction_name),
    
    if is(reactants = false) or is(products = false) then return(false),
    
    return(chem_reaction_entropy(products, reactants))
)$

/* Calculate ΔG° for a reaction by name */
chem_reaction_gibbs_by_name(reaction_name) := block([reactants, products],
    if not(fboundp('chem_reaction_reactants)) then
        return(false),
    reactants: chem_reaction_reactants(reaction_name),
    products: chem_reaction_products(reaction_name),
    
    if is(reactants = false) or is(products = false) then return(false),
    
    return(chem_reaction_gibbs(products, reactants))
)$

/****************************************************************/
/*                                                              */
/*  Thermodynamic Navigation Functions                          */
/*                                                              */
/****************************************************************/

/* Returns an array of all substances in the database */
chem_thermo_substance_array() := 
    map(first, %_THERMO_DATA)$

/* Returns an array of all substances that have data for a specific state */
chem_thermo_substance_state_array(state) := block([filtered],
    filtered: sublist(%_THERMO_DATA, lambda([x], 
        some(lambda([p], sequal(first(p), state)), third(x)))),
    return(map(first, filtered))
)$

/* Returns an array of available states for a substance */
chem_thermo_states(substance) := block([entry],
    entry: _chem_thermo_get_entry(substance),)))
    if is(entry = false) then return(false),
    return(map(first, third(entry)))
)$

/* Returns all phase data for a substance (useful for displaying all phases) */
chem_thermo_all_phases(substance) := block([entry],
    entry: _chem_thermo_get_entry(substance),
    if is(entry = false) then return(false),
    return(map(lambda([p], _chem_thermo_zip(%_THERMO_PHASE_FIELDS, p)), third(entry)))
)$

/****************************************************************/
/*                                                              */
/*  Tag-Based Filtering Functions                               */
/*                                                              */
/****************************************************************/

/* Check if a substance entry has a specific tag */
chem_thermo_has_tag(entry, tag) := 
    member(tag, second(entry))$

/* Returns all entries that have a specific tag */
chem_thermo_filter_by_tag(tag) := 
    sublist(%_THERMO_DATA, lambda([x], chem_thermo_has_tag(x, tag)))$

/* Returns all entries that have ALL specified tags (AND logic) */
chem_thermo_filter_by_tags_all(tag_list) := 
    sublist(%_THERMO_DATA, lambda([x], 
        every(lambda([t], member(t, second(x))), tag_list)))$

/* Returns all entries that have ANY of the specified tags (OR logic) */
chem_thermo_filter_by_tags_any(tag_list) := 
    sublist(%_THERMO_DATA, lambda([x], 
        some(lambda([t], member(t, second(x))), tag_list)))$

/* Returns list of substance formulas with a specific tag */
chem_thermo_substances_by_tag(tag) := 
    map(first, chem_thermo_filter_by_tag(tag))$

/* Returns list of substance formulas with ALL specified tags */
chem_thermo_substances_by_tags_all(tag_list) := 
    map(first, chem_thermo_filter_by_tags_all(tag_list))$

/* Returns list of substance formulas with ANY of the specified tags */
chem_thermo_substances_by_tags_any(tag_list) := 
    map(first, chem_thermo_filter_by_tags_any(tag_list))$

/* Get all tags for a substance */
chem_thermo_get_tags(substance) := block([entry],
    entry: _chem_thermo_get_entry(substance),
    if is(entry = false) then return(false),
    return(second(entry))
)$), 

/* Returns all substances with ALL specified tags (for random selection by user) */
chem_thermo_random_by_tags_all(tag_list) := 
    chem_thermo_substances_by_tags_all(tag_list)$

/* Returns full data for substances filtered by tag */
chem_thermo_data_by_tag(tag) := 
    map(lambda([x], [first(x), second(x), 
        map(lambda([p], _chem_thermo_zip(%_THERMO_PHASE_FIELDS, p)), third(x))]), 
        chem_thermo_filter_by_tag(tag))$

/* Returns substances filtered by tag that have data for a specific state */
chem_thermo_data_by_tag_state(tag, state) := block([tagged, with_state],
    tagged: chem_thermo_filter_by_tag(tag),
    with_state: sublist(tagged, lambda([x], 
        some(lambda([p], sequal(first(p), state)), third(x)))),
    return(map(first, with_state))
)$