%_TAG_HYDROXIDE: "hydroxide"$
%_TAG_HALOGENIDE: "halogenide"$
%_TAG_CHLORIDE: "chloride"$
%_TAG_BROMIDE: "bromide"$
%_TAG_IODIDE: "iodide"$
%_TAG_FLUORIDE: "fluoride"$
%_TAG_SULFIDE: "sulfide"$
%_TAG_SULFATE: "sulfate"$
%_TAG_CARBONATE: "carbonate"$
%_TAG_NITRATE: "nitrate"$
%_TAG_PHOSPHATE: "phosphate"$
%_TAG_ACID: "acid"$
%_TAG_BASE: "base"$
%_TAG_ORGANIC: "organic"$
%_TAG_INORGANIC: "inorganic"$
%_TAG_HYDROCARBON: "hydrocarbon"$
%_TAG_ALCOHOL: "alcohol"$
%_TAG_CARBOXYLIC_ACID: "carboxylic_acid"$
%_TAG_ALDEHYDE: "aldehyde"$
%_TAG_KETONE: "ketone"$
%_TAG_SUGAR: "sugar"$
%_TAG_AMINE: "amine"$
%_TAG_METAL: "metal"$
%_TAG_NONMETAL: "nonmetal"$
%_TAG_HYDRATE: "hydrate"$

/****************************************************************/
/*                                                              */
/*  Thermodynamic Database                                      */
/*                                                              */
/****************************************************************/

/* Database structure: ["Formula", [Tags], [[State, ΔHf°, S°, ΔGf°, Cp°], ...]]
   ΔHf° = Standard enthalpy of formation (kJ/mol)
   S° = Standard molar entropy (J/(mol·K))
   ΔGf° = Standard Gibbs free energy of formation (kJ/mol)
   Cp° = Standard molar heat capacity (J/(mol·K))
   State = Physical state (g, l, s, aq)
   Tags = List of classification tags (applies to substance)
   null indicates the value is not available
   All values at 298.15 K (25°C) and 1 bar */

