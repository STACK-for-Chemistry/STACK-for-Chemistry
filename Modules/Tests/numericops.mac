/* Returns the number of significant digits from numeric input.
   Strings preserve trailing zeros exactly as written.
   Non-string inputs are converted to string first.
   Scientific notation is supported (e.g. "1.230e-4"). */
chem_num_significant_digits(xstr) := block(
	[s, chars, c, mantissa, exponent, in_exp, has_exp, has_decimal,
	 seen_nonzero, sig, frac_digits_allzero, has_any_digit],

	if stringp(xstr) then
		s: sdowncase(xstr)
	else
		s: sdowncase(sconcat(xstr)),
	chars: explode(s),
	mantissa: [],
	exponent: [],
	in_exp: false,
	has_exp: false,

	/* Split mantissa and exponent around 'e'. */
	for c in chars do (
		if c = " " then false
		else if c = "e" then (
			if has_exp then (
				return(false)
			),
			has_exp: true,
			in_exp: true
		)
		else if in_exp then
			exponent: endcons(c, exponent)
		else
			mantissa: endcons(c, mantissa)
	),

	/* Basic exponent validation if present. */
	if has_exp then (
		if length(exponent) = 0 then (
			return(false)
		),
		for c in exponent do (
			if not (c = "+" or c = "-" or c = "0" or c = "1" or c = "2" or c = "3" or c = "4" or c = "5" or c = "6" or c = "7" or c = "8" or c = "9") then (
				return(false)
			)
		)
	),

	has_decimal: false,
	seen_nonzero: false,
	sig: 0,
	frac_digits_allzero: 0,
	has_any_digit: false,

	/* Count significant digits from mantissa.
	   - Ignore leading zeros.
	   - After first non-zero, all digits are significant.
	   - If value is all-zero and decimal exists, decimal zeros are significant
	     as written (e.g. 0.00 -> 2).
	*/
	for c in mantissa do (
		if c = "." then (
			if has_decimal then (
				return(false)
			),
			has_decimal: true
		)
		else if c = "+" or c = "-" then false
		else if c = "0" or c = "1" or c = "2" or c = "3" or c = "4" or c = "5" or c = "6" or c = "7" or c = "8" or c = "9" then (
			has_any_digit: true,
			if seen_nonzero then
				sig: sig + 1
			else if c # "0" then (
				seen_nonzero: true,
				sig: sig + 1
			)
			else if has_decimal then
				frac_digits_allzero: frac_digits_allzero + 1
		)
		else (
			return(false)
		)
	),

	if not has_any_digit then (
		return(false)
	),

	/* Handle all-zero values. */
	if sig = 0 then (
		if has_decimal and frac_digits_allzero > 0 then
			sig: frac_digits_allzero
		else
			sig: 1
	),
	return(sig)
)$
