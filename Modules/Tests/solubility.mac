/****************************************************************/
/*                                                              */
/*  Internal Helper: lookup                                     */
/*                                                              */
/****************************************************************/

/* Lookup value-list for a salt; returns false if not found */
_sol_lookup(salt) := block([entry],
    entry: assoc(salt, %_SOLUBILITY_DB),
    entry  /* returns the [pKsp,cat,ncat,an,nan] list or false */
)$

/****************************************************************/
/*                                                              */
/*  Accessor Functions                                          */
/*                                                              */
/****************************************************************/

/* Ksp is always computed from pKsp to avoid rounding errors */
chem_sol_Ksp(salt) := block([v],
    v: _sol_lookup(salt),
    if is(v = false) then null else float(10^(-v[1]))
)$

chem_sol_pKsp(salt) := block([v],
    v: _sol_lookup(salt),
    if is(v = false) then null else v[1]
)$

chem_sol_cation(salt) := block([v],
    v: _sol_lookup(salt),
    if is(v = false) then "" else v[2]
)$

chem_sol_cation_count(salt) := block([v],
    v: _sol_lookup(salt),
    if is(v = false) then null else v[3]
)$

chem_sol_anion(salt) := block([v],
    v: _sol_lookup(salt),
    if is(v = false) then "" else v[4]
)$

chem_sol_anion_count(salt) := block([v],
    v: _sol_lookup(salt),
    if is(v = false) then null else v[5]
)$

chem_sol_ion_counts(salt) := block([v],
    v: _sol_lookup(salt),
    if is(v = false) then null else [v[3], v[5]]
)$

/* Total number of ions produced per formula unit */
chem_sol_total_ion_count(salt) := block([v],
    v: _sol_lookup(salt),
    if is(v = false) then null else v[3] + v[5]
)$

/* Full entry: [salt, Ksp, pKsp, cation, n_cat, anion, n_an] */
chem_sol_entry(salt) := block([v],
    v: _sol_lookup(salt),
    if is(v = false) then null
    else [salt, float(10^(-v[1])), v[1], v[2], v[3], v[4], v[5]]
)$

/****************************************************************/
/*                                                              */
/*  Molar Solubility Calculation                                */
/*                                                              */
/****************************************************************/

/* Generate LaTeX expression for the molar solubility formula.
   For M_p X_q: s = (Ksp / (p^p * q^q))^(1/(p+q))
   Shows the algebraic derivation with ion concentrations. */
chem_sol_solubility_expression(salt) := block([v, cat, an, p, q, denom_val, exponent],
    v: _sol_lookup(salt),
    if is(v = false) then return(""),
    cat: v[2], p: v[3], an: v[4], q: v[5],

    /* Compute numeric denominator p^p * q^q */
    denom_val: p^p * q^q,

    /* Build exponent 1/(p+q) */
    exponent: sconcat("\\frac{1}{", string(p + q), "}"),

    /* Build final expression: s = (Ksp / (p^p * q^q))^(1/(p+q)) */
    if is(p = 1) and is(q = 1) then
        sconcat("\\sqrt{K_{\\mathrm{sp}}}")
    else if is(denom_val = 1) then
        sconcat("\\left( K_{\\mathrm{sp}} \\right)^{", exponent, "}")
    else
        sconcat("\\left( \\frac{K_{\\mathrm{sp}}}{", string(denom_val), "} \\right)^{", exponent, "}")
)$

/* s = (Ksp / (p^p * q^q))^(1/(p+q))  for M_p X_q */
chem_sol_molar_solubility(salt) := block([v, Ksp, p, q],
    v: _sol_lookup(salt),
    if is(v = false) then return(null),
    Ksp: float(10^(-v[1])), p: v[3], q: v[5],
    stackunits(float((Ksp / (p^p * q^q))^(1/(p + q))), mol*L^(-1))
)$

/* Molar solubility with common-ion effect (bisection solver) */
chem_sol_molar_solubility_common_ion(salt, c_common, common_ion) := block(
    [v, Ksp, p, q, s_lo, s_hi, s_mid, f_mid, f_lo, iter],

    v: _sol_lookup(salt),
    if is(v = false) then return(null),
    Ksp: float(10^(-v[1])), p: v[3], q: v[5],

    /* f(s) = ion-product(s) - Ksp */
    _sol_f(s) := block([cc, ca],
        if is(common_ion = "cation") then (cc: p*s + c_common, ca: q*s)
        else (cc: p*s, ca: q*s + c_common),
        float(cc^p * ca^q - Ksp)
    ),

    s_lo: 0.0,
    s_hi: float((Ksp / (p^p * q^q))^(1/(p + q))) * 2,
    f_lo: _sol_f(s_lo),

    iter: 0,
    while iter < 100 do (
        s_mid: float((s_lo + s_hi) / 2.0),
        f_mid: _sol_f(s_mid),
        if is(f_lo > 0) = is(f_mid > 0) then (s_lo: s_mid, f_lo: f_mid)
        else s_hi: s_mid,
        iter: iter + 1
    ),
    stackunits(float(s_mid), mol*l^(-1))
)$

/****************************************************************/
/*                                                              */
/*  Navigation / Array Functions                                */
/*                                                              */
/****************************************************************/

/* All salt names */
chem_sol_array() := map(first, %_SOLUBILITY_DB)$

/* All salts containing a specific cation */
chem_sol_array_by_cation(cation) := block([result],
    result: [],
    for entry in %_SOLUBILITY_DB do (
        if is(second(entry)[2] = cation) then
            result: append(result, [first(entry)])
    ),
    result
)$

/* All salts containing a specific anion */
chem_sol_array_by_anion(anion) := block([result],
    result: [],
    for entry in %_SOLUBILITY_DB do (
        if is(second(entry)[4] = anion) then
            result: append(result, [first(entry)])
    ),
    result
)$

/* All unique cations */
chem_sol_cation_array() := block([result, cat],
    result: [],
    for entry in %_SOLUBILITY_DB do (
        cat: second(entry)[2],
        if not member(cat, result) then result: append(result, [cat])
    ),
    result
)$

/* All unique anions */
chem_sol_anion_array() := block([result, an],
    result: [],
    for entry in %_SOLUBILITY_DB do (
        an: second(entry)[4],
        if not member(an, result) then result: append(result, [an])
    ),
    result
)$

/* Salts sorted by Ksp ascending (computed from pKsp descending) */
chem_sol_array_sorted_Ksp() := block([pairs, sorted_pairs],
    pairs: map(lambda([e], [first(e), second(e)[1]]), %_SOLUBILITY_DB),
    /* Higher pKsp = lower Ksp, so sort pKsp descending for Ksp ascending */
    sorted_pairs: sort(pairs, lambda([a, b], is(second(a) > second(b)))),
    map(first, sorted_pairs)
)$

/* Salts with Ksp in [Ksp_min, Ksp_max] */
chem_sol_array_Ksp_range(Ksp_min, Ksp_max) := block([result, Ksp],
    result: [],
    for entry in %_SOLUBILITY_DB do (
        Ksp: float(10^(-second(entry)[1])),
        if is(Ksp >= Ksp_min) and is(Ksp <= Ksp_max) then
            result: append(result, [first(entry)])
    ),
    result
)$

/* Salts with a specific cation stoichiometric coefficient */
chem_sol_array_by_cation_count(n) := block([result],
    result: [],
    for entry in %_SOLUBILITY_DB do (
        if is(second(entry)[3] = n) then
            result: append(result, [first(entry)])
    ),
    result
)$

/* Salts with a specific anion stoichiometric coefficient */
chem_sol_array_by_anion_count(n) := block([result],
    result: [],
    for entry in %_SOLUBILITY_DB do (
        if is(second(entry)[5] = n) then
            result: append(result, [first(entry)])
    ),
    result
)$

/* Salts with a specific total number of ions (cation_count + anion_count) */
chem_sol_array_by_total_ions(n) := block([result],
    result: [],
    for entry in %_SOLUBILITY_DB do (
        if is(second(entry)[3] + second(entry)[5] = n) then
            result: append(result, [first(entry)])
    ),
    result
)$

/****************************************************************/
/*                                                              */
/*  Precipitation Check Functions                               */
/*                                                              */
/****************************************************************/

chem_sol_ion_product(c_cation, c_anion, salt) := block([v, p, q],
    v: _sol_lookup(salt),
    if is(v = false) then return(null),
    p: v[3], q: v[5],
    float(c_cation^p * c_anion^q)
)$

chem_sol_precipitation_check(c_cation, c_anion, salt) := block([Q, Ksp],
    Q: chem_sol_ion_product(c_cation, c_anion, salt),
    Ksp: chem_sol_Ksp(salt),
    if is(Q = null) or is(Ksp = null) then return(null),
    if is(Q > Ksp) then "precipitates"
    else if is(abs(Q - Ksp) / Ksp < 0.001) then "saturated"
    else "unsaturated"
)$

chem_sol_max_concentration(c_known, salt, ion_type) := block([v, Ksp, p, q],
    v: _sol_lookup(salt),
    if is(v = false) then return(null),
    Ksp: float(10^(-v[1])), p: v[3], q: v[5],
    if is(ion_type = "cation") then float((Ksp / c_known^q)^(1/p))
    else if is(ion_type = "anion") then float((Ksp / c_known^p)^(1/q))
    else null
)$

/****************************************************************/
/*                                                              */
/*  Dissolution Equation String (mhchem format)                 */
/*                                                              */
/****************************************************************/

/* Returns a LaTeX-formatted dissolution equation with \ce{} included,
   so the question text only needs \({@...@}\) without manual \ce wrapping. */
chem_sol_dissolution_equation(salt) := block([v, cat, an, p, q, rhs_cat, rhs_an],
    v: _sol_lookup(salt),
    if is(v = false) then return(""),
    cat: v[2], p: v[3], an: v[4], q: v[5],

    if is(p = 1) then rhs_cat: cat else rhs_cat: sconcat(string(p), " ", cat),
    if is(q = 1) then rhs_an: an  else rhs_an:  sconcat(string(q), " ", an),

    sconcat("\\ce{", salt, " -> ", rhs_cat, " + ", rhs_an, "}")
)$

/****************************************************************/
/*                                                              */
/*  Equilibrium Expression Functions                            */
/*                                                              */
/****************************************************************/

/* Generate Ksp expression in bracket notation with mhchem rendering. */
chem_sol_Ksp_expression(salt) := block([v, cat, an, p, q, cat_part, an_part],
    v: _sol_lookup(salt),
    if is(v = false) then return(""),
    cat: v[2], p: v[3], an: v[4], q: v[5],

    if is(p = 1) then cat_part: sconcat("[\\ce{", cat, "}]")
    else cat_part: sconcat("[\\ce{", cat, "}]^", string(p)),

    if is(q = 1) then an_part: sconcat("[\\ce{", an, "}]")
    else an_part: sconcat("[\\ce{", an, "}]^", string(q)),

    sconcat(cat_part, " \\cdot ", an_part)
)$

/* Generate Ksp expression in activity notation with mhchem rendering.
   Includes denominator a(salt) for pedagogical purposes. */
chem_sol_Ksp_activity_expression(salt) := block([v, cat, an, p, q, cat_part, an_part],
    v: _sol_lookup(salt),
    if is(v = false) then return(""),
    cat: v[2], p: v[3], an: v[4], q: v[5],

    if is(p = 1) then cat_part: sconcat("a(\\ce{", cat, "})")
    else cat_part: sconcat("a(\\ce{", cat, "})^", string(p)),

    if is(q = 1) then an_part: sconcat("a(\\ce{", an, "})")
    else an_part: sconcat("a(\\ce{", an, "})^", string(q)),

    sconcat("\\frac{", cat_part, " \\cdot ", an_part, "}{a(\\ce{", salt, "})}")
)$

/* Simplified activity expression (denominator = 1 for pure solid) with mhchem rendering. */
chem_sol_Ksp_activity_expression_simplified(salt) := block([v, cat, an, p, q, cat_part, an_part],
    v: _sol_lookup(salt),
    if is(v = false) then return(""),
    cat: v[2], p: v[3], an: v[4], q: v[5],

    if is(p = 1) then cat_part: sconcat("a(\\ce{", cat, "})")
    else cat_part: sconcat("a(\\ce{", cat, "})^", string(p)),

    if is(q = 1) then an_part: sconcat("a(\\ce{", an, "})")
    else an_part: sconcat("a(\\ce{", an, "})^", string(q)),

    sconcat(cat_part, " \\cdot ", an_part)
)$
