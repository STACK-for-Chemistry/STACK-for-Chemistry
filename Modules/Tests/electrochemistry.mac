/*  Author Alexander Pitzer
    ETH Zurich
    Copyright (C) 2026 Alexander Pitzer

    Electrochemistry helper module based on standard reduction potentials.
    Restructured to follow acid-base module pattern with direct string equality.
    Data layout is flat for fast index access:
    [oxidant, reductant, n_e, E0, oxidant, reductant, n_e, E0, ...]
*/

%_ELECTROCHEM_DATA: [
    "F2", "2F-", 2, 2.87,
    "Ce^{4+}", "Ce^{3+}", 1, 1.61,
    "MnO4^- + 8H+", "Mn^{2+} + 4H2O", 5, 1.51,
    "Cl2", "2Cl-", 2, 1.36,
    "Cr2O7^{2-} + 14H+", "2Cr^{3+} + 7H2O", 6, 1.33,
    "O2 + 4H+", "2H2O", 4, 1.23,
    "MnO2 + 4H+", "Mn^{2+} + 2H2O", 2, 1.23,
    "Br2", "2Br-", 2, 1.06,
    "NO3^- + 4H+", "NO + 2H2O", 3, 0.96,
    "Ag+", "Ag", 1, 0.80,
    "Fe^{3+}", "Fe^{2+}", 1, 0.77,
    "O2 + 2H+", "H2O2", 2, 0.68,
    "MnO4^- + 2H2O", "MnO2 + 4OH-", 3, 0.59,
    "I2", "2I-", 2, 0.54,
    "O2 + 2H2O", "4OH-", 4, 0.40,
    "[Fe(CN)6]^{3-}", "[Fe(CN)6]^{4-}", 1, 0.370,
    "Cu^{2+}", "Cu", 2, 0.34,
    "AgCl", "Ag + Cl-", 1, 0.222,
    "H+", "0.5H2", 2, 0.00,
    "Pb^{2+}", "Pb", 2, -0.13,
    "Sn^{2+}", "Sn", 2, -0.14,
    "Ni^{2+}", "Ni", 2, -0.28,
    "Cd^{2+}", "Cd", 2, -0.40,
    "Fe^{2+}", "Fe", 2, -0.44,
    "Zn^{2+}", "Zn", 2, -0.76,
    "2H2O", "H2 + 2OH-", 2, -0.83,
    "Al^{3+}", "Al", 3, -1.66,
    "Mg^{2+}", "Mg", 2, -2.37,
    "Na+", "Na", 1, -2.71,
    "Ca^{2+}", "Ca", 2, -2.87,
    "Ba^{2+}", "Ba", 2, -2.90,
    "K+", "K", 1, -2.93,
    "Li+", "Li", 1, -3.05,
    "Co^{2+}", "Co", 2, -0.28,
    "Mn^{2+}", "Mn", 2, -1.18,
    "Cu+", "Cu", 1, 0.52
]$

/* Helper: find index of oxidant (returns position of oxidant, or 0 if not found) */
_electrochem_find_oxidant(oxidant) := block([i, n, result],
    n: length(%_ELECTROCHEM_DATA),
    result: 0,
    i: 1,
    while i <= n do (
        if is(%_ELECTROCHEM_DATA[i] = oxidant) then (result: i, return(result)),
        i: i + 4
    ),
    result
)$

/* Helper: find index of reductant (returns starting position of entry, or 0 if not found) */
_electrochem_find_reductant(reductant) := block([i, n, result],
    n: length(%_ELECTROCHEM_DATA),
    result: 0,
    i: 2,
    while i <= n do (
        if is(%_ELECTROCHEM_DATA[i] = reductant) then (result: i - 1, return(result)),
        i: i + 4
    ),
    result
)$

/* Helper: find oxidant/reductant pair (returns position of oxidant, or 0 if not found) */
_electrochem_find_pair(oxidant, reductant) := block([i, n, result],
    n: length(%_ELECTROCHEM_DATA),
    result: 0,
    i: 1,
    while i <= n do (
        if is(%_ELECTROCHEM_DATA[i] = oxidant) and is(%_ELECTROCHEM_DATA[i + 1] = reductant) then (result: i, return(result)),
        i: i + 4
    ),
    result
)$

/* Get E0 for an oxidant/reductant pair - returns null if not found */
chem_electrochem_E0(oxidant, reductant) := block([idx],
    idx: _electrochem_find_pair(oxidant, reductant),
    if is(idx = 0) then null else %_ELECTROCHEM_DATA[idx + 3]
)$

/* Get number of electrons transferred for a pair - returns null if not found */
chem_electrochem_n(oxidant, reductant) := block([idx],
    idx: _electrochem_find_pair(oxidant, reductant),
    if is(idx = 0) then null else %_ELECTROCHEM_DATA[idx + 2]
)$

/* Get reductant for a given oxidant - returns empty string if not found */
chem_electrochem_reductant(oxidant) := block([idx],
    idx: _electrochem_find_oxidant(oxidant),
    if is(idx = 0) then "" else %_ELECTROCHEM_DATA[idx + 1]
)$

/* Get oxidant for a given reductant - returns empty string if not found */
chem_electrochem_oxidant(reductant) := block([idx],
    idx: _electrochem_find_reductant(reductant),
    if is(idx = 0) then "" else %_ELECTROCHEM_DATA[idx]
)$

/* Get complete pair data: [oxidant, reductant, n_e, E0] - returns empty list if not found */
chem_electrochem_pair_data(oxidant, reductant) := block([idx],
    idx: _electrochem_find_pair(oxidant, reductant),
    if is(idx = 0) then []
    else [%_ELECTROCHEM_DATA[idx], %_ELECTROCHEM_DATA[idx + 1], %_ELECTROCHEM_DATA[idx + 2], %_ELECTROCHEM_DATA[idx + 3]]
)$

/* Generate half-equation string with LaTeX formatting */
chem_electrochem_half_equation(oxidant, reductant) := block([idx, n],
    idx: _electrochem_find_pair(oxidant, reductant),
    if is(idx = 0) then return(""),
    n: %_ELECTROCHEM_DATA[idx + 2],
    sconcat("\\ce{", oxidant, " + ", string(n), " e^- -> ", reductant, "}")
)$

/* Navigation arrays */
chem_electrochem_oxidant_array() := block([result, i, n],
    result: [],
    n: length(%_ELECTROCHEM_DATA),
    i: 1,
    while i <= n do (
        result: append(result, [%_ELECTROCHEM_DATA[i]]),
        i: i + 4
    ),
    result
)$

chem_electrochem_reductant_array() := block([result, i, n],
    result: [],
    n: length(%_ELECTROCHEM_DATA),
    i: 2,
    while i <= n do (
        result: append(result, [%_ELECTROCHEM_DATA[i]]),
        i: i + 4
    ),
    result
)$

chem_electrochem_pairs_array() := block([result, i, n],
    result: [],
    n: length(%_ELECTROCHEM_DATA),
    i: 1,
    while i <= n do (
        result: append(result, [[%_ELECTROCHEM_DATA[i], %_ELECTROCHEM_DATA[i + 1]]]),
        i: i + 4
    ),
    result
)$

chem_electrochem_strong_oxidant_array(E_min) := block([result, i, n, E0],
    result: [],
    n: length(%_ELECTROCHEM_DATA),
    i: 1,
    while i <= n do (
        E0: %_ELECTROCHEM_DATA[i + 3],
        if numberp(E0) and is(E0 >= E_min) then result: append(result, [%_ELECTROCHEM_DATA[i]]),
        i: i + 4
    ),
    result
)$

chem_electrochem_strong_reductant_array(E_max) := block([result, i, n, E0],
    result: [],
    n: length(%_ELECTROCHEM_DATA),
    i: 1,
    while i <= n do (
        E0: %_ELECTROCHEM_DATA[i + 3],
        if numberp(E0) and is(E0 <= E_max) then result: append(result, [%_ELECTROCHEM_DATA[i + 1]]),
        i: i + 4
    ),
    result
)$

/* Cell voltage (standard conditions):
   Ecell = E0(cathode reduction) - E0(anode reduction) */
chem_electrochem_cell_potential(cathode_ox, cathode_red, anode_ox, anode_red) := block([E_cath, E_an],
    E_cath: chem_electrochem_E0(cathode_ox, cathode_red),
    E_an: chem_electrochem_E0(anode_ox, anode_red),
    if is(E_cath = null) or is(E_an = null) then null
    else float(E_cath - E_an)
)$

/* Check if a cell reaction is spontaneous (Ecell > 0) */
chem_electrochem_spontaneous(cathode_ox, cathode_red, anode_ox, anode_red) := block([Ecell],
    Ecell: chem_electrochem_cell_potential(cathode_ox, cathode_red, anode_ox, anode_red),
    if is(Ecell = null) then false else is(Ecell > 0)
)$

/* Legacy alias matching existing module style */
chem_electrochem_array() := chem_electrochem_oxidant_array()$
