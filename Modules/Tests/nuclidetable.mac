/****************************************************************/
/*                                                              */
/*  Nuclide Retrieval Functions    Modules/Tests/nuclidetable.mac                             */
/*                                                              */
/****************************************************************/

/* ---- Internal helpers ---- */

chem_nuc_get_entry(id) := block([d],
    d: assoc(id, %_NUCLIDE_DATA),
    if is(d = false) then false else [id, d]
)$

chem_nuc_get_data(id) := assoc(id, %_NUCLIDE_DATA)$

chem_nuc_id_from_ZN(z, n) := block([sym],
    if is(z < 1) or is(n < 0) then return(false),
    sym: chem_element(z),
    if is(sym = false) then false
    else sconcat("^{", z + n, "}", sym)
)$

/* ---- Lookup by Z, N, A ---- */

chem_nuc_by_Z(z) := block([results],
    results: [],
    for entry in %_NUCLIDE_DATA do (
        if entry[2][1] = z then
            results: cons(entry[1], results)
    ),
    reverse(results)
)$

chem_nuc_by_N(n) := block([results],
    results: [],
    for entry in %_NUCLIDE_DATA do (
        if entry[2][2] = n then
            results: cons(entry[1], results)
    ),
    reverse(results)
)$

chem_nuc_by_A(a) := block([results],
    results: [],
    for entry in %_NUCLIDE_DATA do (
        if entry[2][1] + entry[2][2] = a then
            results: cons(entry[1], results)
    ),
    reverse(results)
)$

chem_nuc_by_ZN(z, n) := block([results],
    results: [],
    for entry in %_NUCLIDE_DATA do (
        if entry[2][1] = z and entry[2][2] = n then
            results: cons(entry[1], results)
    ),
    reverse(results)
)$

/* ---- Field extractors ---- */

chem_nuc_Z(id) := block([d],
    d: chem_nuc_get_data(id),
    if is(d = false) then false else d[1]
)$

chem_nuc_N(id) := block([d],
    d: chem_nuc_get_data(id),
    if is(d = false) then false else d[2]
)$

chem_nuc_A(id) := block([d],
    d: chem_nuc_get_data(id),
    if is(d = false) then false else d[1] + d[2]
)$

chem_nuc_levels(id) := block([d],
    d: chem_nuc_get_data(id),
    if is(d = false) then false else d[3]
)$

chem_nuc_halflives(id) := block([d],
    d: chem_nuc_get_data(id),
    if is(d = false) then false else d[4]
)$

chem_nuc_halflife_units(id) := block([d],
    d: chem_nuc_get_data(id),
    if is(d = false) then false else d[5]
)$

chem_nuc_decay_modes(id) := block([d],
    d: chem_nuc_get_data(id),
    if is(d = false) then false else d[6]
)$

chem_nuc_branching(id) := block([d],
    d: chem_nuc_get_data(id),
    if is(d = false) then false else d[7]
)$

/* ---- Ground-state convenience functions ---- */

chem_nuc_gs_halflife(id) := block([hl],
    hl: chem_nuc_halflives(id),
    if is(hl = false) then false else first(hl)
)$

chem_nuc_gs_halflife_unit(id) := block([u],
    u: chem_nuc_halflife_units(id),
    if is(u = false) then false else first(u)
)$

chem_nuc_gs_decay_modes(id) := block([dm],
    dm: chem_nuc_decay_modes(id),
    if is(dm = false) then false else first(dm)
)$

chem_nuc_gs_branching(id) := block([br],
    br: chem_nuc_branching(id),
    if is(br = false) then false else first(br)
)$

/* Unit conversion table for half-lives to seconds */
%_HALFLIFE_UNIT_FACTORS: [
    ["fs", 1e-15], ["ps", 1e-12], ["ns", 1e-9],  ["us", 1e-6],
    ["ms", 1e-3],  ["s",  1],      ["m",  60],    ["h",  3600],
    ["d",  86400],  ["y",  31557600]
]$

/* ---- Half-life unit conversion to seconds ---- */

chem_nuc_halflife_to_seconds(val, unit) := block([factor],
    if is(val = null) or is(unit = null) then return(false),
    factor: assoc(unit, %_HALFLIFE_UNIT_FACTORS),
    if is(factor = false) then false else val * factor
)$

chem_nuc_gs_halflife_s(id) := block([hl, u],
    hl: chem_nuc_gs_halflife(id),
    u:  chem_nuc_gs_halflife_unit(id),
    if is(hl = false) or is(u = false) then false
    else chem_nuc_halflife_to_seconds(hl, u)
)$

/* ---- Filtering / searching ---- */

chem_nuc_with_decay_mode(mode) := block([results, dm],
    results: [],
    for entry in %_NUCLIDE_DATA do (
        dm: first(entry[2][6]),
        if member(mode, dm) then
            results: cons(entry[1], results)
    ),
    reverse(results)
)$

chem_nuc_halflife_range(t_min, t_max) := block([results, hl_s, v, u],
    results: [],
    for entry in %_NUCLIDE_DATA do (
        v: first(entry[2][4]),
        u: first(entry[2][5]),
        hl_s: chem_nuc_halflife_to_seconds(v, u),
        if hl_s # false and hl_s >= t_min and hl_s <= t_max then
            results: cons(entry[1], results)
    ),
    reverse(results)
)$

chem_nuc_radioactive_isotopes(z) := chem_nuc_by_Z(z)$

chem_nuc_num_levels(id) := block([lvl],
    lvl: chem_nuc_levels(id),
    if is(lvl = false) then 0 else length(lvl)
)$

chem_nuc_exists(id) := assoc(id, %_NUCLIDE_DATA) # false$

%_NUCLIDE_ALL_IDS : map(first, %_NUCLIDE_DATA)$

chem_nuc_all_ids() := %_NUCLIDE_ALL_IDS$

chem_nuc_gs_dominant_mode(id) := block([modes, ratios, best_mode, best_ratio, i],
    modes:  chem_nuc_gs_decay_modes(id),
    ratios: chem_nuc_gs_branching(id),
    if is(modes = false) or is(ratios = false) then return(false),
    best_mode: false,
    best_ratio: -1,
    for i: 1 thru length(modes) do (
        if not is(ratios[i] = null) then (
            if is(ratios[i] > best_ratio) then (
                best_ratio: ratios[i],
                best_mode:  modes[i]
            )
        )
    ),
    best_mode
)$

/* ---- Decay products ---- */

chem_nuc_alpha_product(id) := block([d],
    d: chem_nuc_get_data(id),
    if is(d = false) then false
    else chem_nuc_id_from_ZN(d[1] - 2, d[2] - 2)
)$

chem_nuc_beta_minus_product(id) := block([d],
    d: chem_nuc_get_data(id),
    if is(d = false) then false
    else chem_nuc_id_from_ZN(d[1] + 1, d[2] - 1)
)$

chem_nuc_beta_plus_product(id) := block([d],
    d: chem_nuc_get_data(id),
    if is(d = false) then false
    else chem_nuc_id_from_ZN(d[1] - 1, d[2] + 1)
)$

chem_nuc_decay_product(id, mode) := block([],
    if sequal(mode, "A") or sequal(mode, "ALPHA") then
        chem_nuc_alpha_product(id)
    else if sequal(mode, "B-") or sequal(mode, "BETA-") then
        chem_nuc_beta_minus_product(id)
    else if sequal(mode, "B+") or sequal(mode, "BETA+") then
        chem_nuc_beta_plus_product(id)
    else false
)$

/* ---- Ionization helpers ---- */

chem_nuc_parse_oxidation_charge(ox) := block([clean, chars, n, i, sign, charge_num],
    if is(ox = false) or is(ox = null) then return(false),
    clean: ssubst("", " ", ox),
    chars: charlist(clean),
    n: length(chars),
    if is(n = 0) then return(false),

    sign: 1,
    i: 1,
    if sequal(chars[i], "+") then (
        sign: 1,
        i: i + 1
    ) else if sequal(chars[i], "-") then (
        sign: -1,
        i: i + 1
    ),

    charge_num: 0,
    while i <= n and cgreaterp(chars[i], "/") and clessp(chars[i], ":") do (
        charge_num: charge_num * 10 + (cint(chars[i]) - 48),
        i: i + 1
    ),

    if is(charge_num = 0) then false
    else sign * charge_num
)$

chem_nuc_charge_string(charge) := block([],
    if is(charge > 0) then sconcat(charge, "+")
    else if is(charge < 0) then sconcat(-charge, "-")
    else "0"
)$

chem_nuc_symbol(id) := block([parsed],
    if is(id = false) or is(id = null) then return(false),
    parsed: chem_parse_formula(id),
    if is(parsed = false) or length(parsed) = 0 then false
    else first(first(parsed))
)$

chem_nuc_typical_charge(id) := block([d, sym, ox],
    d: chem_nuc_get_data(id),
    if is(d = false) then return(false),
    sym: chem_nuc_symbol(id),
    if is(sym = false) then return(false),
    ox: chem_data(sym, "OxidationStates"),
    chem_nuc_parse_oxidation_charge(ox)
)$

chem_nuc_ionize(id, charge) := block([d, z, n, sym],
    d: chem_nuc_get_data(id),
    if is(d = false) then return(false),
    z: d[1],
    n: d[2],
    sym: chem_nuc_symbol(id),
    if is(sym = false) then return(false),
    sconcat("^{", z + n, "}", sym, "^{", chem_nuc_charge_string(charge), "}")
)$

chem_nuc_ionize_typical(id) := block([q],
    q: chem_nuc_typical_charge(id),
    if is(q = false) then false else chem_nuc_ionize(id, q)
)$
