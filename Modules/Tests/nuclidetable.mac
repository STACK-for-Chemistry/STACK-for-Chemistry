/****************************************************************/
/*  Nuclide Table for STACK                                     */
/*                                                              */
/*  V1.0 March 2026                                             */
/*                                                              */
/*  Contains nuclear data from NNDC NuDat database              */
/*                                                              */
/****************************************************************/

/****************************************************************/
/*                                                              */
/*  Nuclide Database                                            */
/*                                                              */
/****************************************************************/

/* Database structure: ["Nuclide_ID", [Z, N, LevelEnergies, Halflives, HalflifeUnits,
                                       DecayModes, BranchingRatios]]

   Field descriptions:
   - Nuclide_ID: String identifier (e.g., "185Tl")
   - Z: Atomic number (protons)
   - N: Neutron number
   - LevelEnergies: Array of excited state energies in MeV [0, 0.455, ...] (0 for ground state)
   - Halflives: Array of half-life values [19.5, 1.8, ...]
   - HalflifeUnits: Array of units ["s", "s", ...] (s, ms, us, ns, ps, fs, m, h, d, y, keV, MeV, eV)
   - DecayModes: Nested array [["mode1", "mode2"], ["mode1"]] for each level
   - BranchingRatios: Nested array [[ratio1, ratio2], [ratio1]] matching DecayModes (percentages)

   Note: null indicates missing or not applicable data
   Multiple excited states are combined in arrays for the same isotope
   Example: ["185Tl", [81, 104, [0, 0.455], [19.5, 1.8], ["s", "s"],
                       [["EC+B+"], ["IT"]], [[100], [100]]]]
*/

%_NUCLIDE_DATA: [
    /* Neutron (Z=0) */
    ["Neutron", [0, 1, [0], [608.9], ["s"], [["B-"]], [[100]]]],

    /* H (Z=1) */
    ["3H", [1, 2, [0], [12.3221], ["y"], [["B-"]], [[100]]]],

    /* He (Z=2) */
    ["6He", [2, 4, [0], [807.12], ["ms"], [["B-"]], [[100]]]],
    ["8He", [2, 6, [0], [119], ["ms"], [["B-", "B-N"]], [[100, 16]]]],

    /* Hg (Z=80) */
    ["170Hg", [80, 90, [0], [80], ["us"], [["A"]], [[100]]]],
    ["171Hg", [80, 91, [0], [59], ["us"], [["A"]], [[100]]]],
    ["172Hg", [80, 92, [0], [231], ["us"], [["A"]], [[100]]]],
    ["173Hg", [80, 93, [0], [0.8], ["ms"], [["A"]], [[100]]]],
    ["174Hg", [80, 94, [0], [1.9], ["ms"], [["A"]], [[100]]]],
    ["175Hg", [80, 95, [0], [10.2], ["ms"], [["A"]], [[100]]]],
    ["176Hg", [80, 96, [0], [20], ["ms"], [["A", "B+"]], [[94, 6]]]],
    ["177Hg", [80, 97, [0], [117], ["ms"], [["A"]], [[100]]]],
    ["178Hg", [80, 98, [0], [266], ["ms"], [["A", "B+"]], [[89, 11]]]],
    ["179Hg", [80, 99, [0], [1.05], ["s"], [["A", "B+", "ECP"]], [[75, 25, 0.21]]]],
    ["180Hg", [80, 100, [0], [2.58], ["s"], [["A", "B+"]], [[48, 52]]]],
    ["181Hg", [80, 101, [0], [3.6], ["s"], [["A", "B+", "ECP", "ECA"]], [[24, 76, 0.012, 9e-06]]]],
    ["182Hg", [80, 102, [0], [10.88], ["s"], [["A", "B+"]], [[13.8, 86.2]]]],
    ["183Hg", [80, 103, [0], [8.9], ["s"], [["A", "B+", "ECP"]], [[23.6, 76.4, 0.00026]]]],
    ["184Hg", [80, 104, [0], [30.9], ["s"], [["B+", "A"]], [[98.89, 1.11]]]],
    ["185Hg", [80, 105, [0, 0.1037], [48.2, 29], ["s", "s"], [["B+", "A"], ["B+", "IT", "A"]], [[94, 6], [42, 58, 0.03]]]],
    ["186Hg", [80, 106, [0], [1.38], ["m"], [["B+", "A"]], [[99.984, 0.016]]]],
    ["187Hg", [80, 107, [0, null], [1.9, 2.4], ["m", "m"], [["B+"], ["B+"]], [[100], [100]]]],
    ["188Hg", [80, 108, [0], [3.25], ["m"], [["B+", "A"]], [[99.999963, 3.7e-05]]]],
    ["189Hg", [80, 109, [0, 0.08], [8, 8.6], ["m", "m"], [["B+"], ["B+"]], [[100], [100]]]],
    ["190Hg", [80, 110, [0], [20], ["m"], [["B+"]], [[100]]]],
    ["191Hg", [80, 111, [0, 0.128], [49, 50.8], ["m", "m"], [["B+"], ["B+"]], [[100], [100]]]],
    ["192Hg", [80, 112, [0], [4.85], ["h"], [["EC"]], [[100]]]],
    ["193Hg", [80, 113, [0, 0.14076], [3.8, 11.1], ["h", "h"], [["B+"], ["B+", "IT"]], [[100], [92.8, 7.2]]]],
    ["194Hg", [80, 114, [0], [447], ["y"], [["EC"]], [[100]]]],
    ["195Hg", [80, 115, [0, 0.17607], [10.68, 41.6], ["h", "h"], [["B+"], ["B+", "IT"]], [[100], [45.8, 54.2]]]],
    ["197Hg", [80, 117, [0, 0.29893000000000003], [64.96, 23.82], ["h", "h"], [["B+"], ["IT", "B+"]], [[100], [94.68, 5.32]]]],
    ["199Hg", [80, 119, [0.5324800000000001], [42.66], ["m"], [["IT"]], [[100]]]],
    ["203Hg", [80, 123, [0], [46.612], ["d"], [["B-"]], [[100]]]],
    ["205Hg", [80, 125, [0], [5.1], ["m"], [["B-"]], [[100]]]],
    ["206Hg", [80, 126, [0], [8.32], ["m"], [["B-"]], [[100]]]],
    ["207Hg", [80, 127, [0], [2.9], ["m"], [["B-"]], [[100]]]],
    ["208Hg", [80, 128, [0], [135], ["s"], [["B-"]], [[100]]]],
    ["209Hg", [80, 129, [0], [6.3], ["s"], [["B-"]], [[100]]]],
    ["210Hg", [80, 130, [0], [63.7], ["s"], [["B-", "B-N"]], [[100, 2.2]]]],
    ["211Hg", [80, 131, [0], [26.4], ["s"], [["B-", "B-N"]], [[100, 6.3]]]]
]$

/****************************************************************/
/*                                                              */
/*  Nuclide Retrieval Functions                                 */
/*                                                              */
/****************************************************************/

/* ---- Internal helpers ---- */

nuc_get_entry(id) := block([result],
    result: false,
    for entry in %_NUCLIDE_DATA do (
        if sequal(entry[1], id) then (
            result: entry,
            return(result)
        )
    ),
    result
)$

nuc_get_data(id) := block([e],
    e: nuc_get_entry(id),
    if is(e = false) then false else e[2]
)$

/* ---- Lookup by Z, N, A ---- */

nuc_by_Z(z) := block([results],
    results: [],
    for entry in %_NUCLIDE_DATA do (
        if is(entry[2][1] = z) then
            results: endcons(entry[1], results)
    ),
    results
)$

nuc_by_N(n) := block([results],
    results: [],
    for entry in %_NUCLIDE_DATA do (
        if is(entry[2][2] = n) then
            results: endcons(entry[1], results)
    ),
    results
)$

nuc_by_A(a) := block([results],
    results: [],
    for entry in %_NUCLIDE_DATA do (
        if is(entry[2][1] + entry[2][2] = a) then
            results: endcons(entry[1], results)
    ),
    results
)$

nuc_by_ZN(z, n) := block([results],
    results: [],
    for entry in %_NUCLIDE_DATA do (
        if is(entry[2][1] = z) and is(entry[2][2] = n) then
            results: endcons(entry[1], results)
    ),
    results
)$

/* ---- Field extractors ---- */

nuc_Z(id) := block([d],
    d: nuc_get_data(id),
    if is(d = false) then false else d[1]
)$

nuc_N(id) := block([d],
    d: nuc_get_data(id),
    if is(d = false) then false else d[2]
)$

nuc_A(id) := block([d],
    d: nuc_get_data(id),
    if is(d = false) then false else d[1] + d[2]
)$

nuc_levels(id) := block([d],
    d: nuc_get_data(id),
    if is(d = false) then false else d[3]
)$

nuc_halflives(id) := block([d],
    d: nuc_get_data(id),
    if is(d = false) then false else d[4]
)$

nuc_halflife_units(id) := block([d],
    d: nuc_get_data(id),
    if is(d = false) then false else d[5]
)$

nuc_decay_modes(id) := block([d],
    d: nuc_get_data(id),
    if is(d = false) then false else d[6]
)$

nuc_branching(id) := block([d],
    d: nuc_get_data(id),
    if is(d = false) then false else d[7]
)$

/* ---- Ground-state convenience functions ---- */

nuc_gs_halflife(id) := block([hl],
    hl: nuc_halflives(id),
    if is(hl = false) then false else first(hl)
)$

nuc_gs_halflife_unit(id) := block([u],
    u: nuc_halflife_units(id),
    if is(u = false) then false else first(u)
)$

nuc_gs_decay_modes(id) := block([dm],
    dm: nuc_decay_modes(id),
    if is(dm = false) then false else first(dm)
)$

nuc_gs_branching(id) := block([br],
    br: nuc_branching(id),
    if is(br = false) then false else first(br)
)$

/* ---- Half-life unit conversion to seconds ---- */

nuc_halflife_to_seconds(val, unit) := block([],
    if is(val = null) or is(unit = null) then false
    else if sequal(unit, "fs") then val * 1e-15
    else if sequal(unit, "ps") then val * 1e-12
    else if sequal(unit, "ns") then val * 1e-9
    else if sequal(unit, "us") then val * 1e-6
    else if sequal(unit, "ms") then val * 1e-3
    else if sequal(unit, "s")  then val
    else if sequal(unit, "m")  then val * 60
    else if sequal(unit, "h")  then val * 3600
    else if sequal(unit, "d")  then val * 86400
    else if sequal(unit, "y")  then val * 31557600
    else false
)$

nuc_gs_halflife_s(id) := block([hl, u],
    hl: nuc_gs_halflife(id),
    u:  nuc_gs_halflife_unit(id),
    if is(hl = false) or is(u = false) then false
    else nuc_halflife_to_seconds(hl, u)
)$

/* ---- Filtering / searching ---- */

nuc_with_decay_mode(mode) := block([results, dm],
    results: [],
    for entry in %_NUCLIDE_DATA do (
        dm: first(entry[2][6]),
        if member(mode, dm) then
            results: endcons(entry[1], results)
    ),
    results
)$

nuc_halflife_range(t_min, t_max) := block([results, hl_s],
    results: [],
    for entry in %_NUCLIDE_DATA do (
        hl_s: block([v, u],
            v: first(entry[2][4]),
            u: first(entry[2][5]),
            nuc_halflife_to_seconds(v, u)
        ),
        if not is(hl_s = false) then (
            if is(hl_s >= t_min) and is(hl_s <= t_max) then
                results: endcons(entry[1], results)
        )
    ),
    results
)$

nuc_radioactive_isotopes(z) := nuc_by_Z(z)$

nuc_num_levels(id) := block([lvl],
    lvl: nuc_levels(id),
    if is(lvl = false) then 0 else length(lvl)
)$

nuc_exists(id) := not is(nuc_get_entry(id) = false)$

nuc_all_ids() := block([results],
    results: [],
    for entry in %_NUCLIDE_DATA do
        results: endcons(entry[1], results),
    results
)$

nuc_gs_dominant_mode(id) := block([modes, ratios, best_mode, best_ratio, i],
    modes:  nuc_gs_decay_modes(id),
    ratios: nuc_gs_branching(id),
    if is(modes = false) or is(ratios = false) then return(false),
    best_mode: false,
    best_ratio: -1,
    for i: 1 thru length(modes) do (
        if not is(ratios[i] = null) then (
            if is(ratios[i] > best_ratio) then (
                best_ratio: ratios[i],
                best_mode:  modes[i]
            )
        )
    ),
    best_mode
)$

/* Display helper: converts "211Hg" to LaTeX "^{211}Hg" for use in question text */
nuc_latex(id) := block([i, digits, element, c],
    if sequal(id, "Neutron") then return("n"),
    digits: "",
    element: "",
    for i: 1 thru slength(id) do (
        c: charat(id, i),
        if digitcharp(c) then
            digits: sconcat(digits, c)
        else
            element: sconcat(element, c)
    ),
    if sequal(digits, "") then id
    else sconcat("^{", digits, "}", element)
)$