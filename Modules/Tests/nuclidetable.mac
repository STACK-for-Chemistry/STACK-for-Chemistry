/* nuc_halflife_to_seconds(val, unit) := block([],
    if is(val = null) or is(unit = null) then false
    else if is(unit = "fs") then val * 1e-15
    else if is(unit = "ps") then val * 1e-12
    else if is(unit = "ns") then val * 1e-9
    else if is(unit = "us") then val * 1e-6
    else if is(unit = "ms") then val * 1e-3
    else if is(unit = "s")  then val
    else if is(unit = "m")  then val * 60
    else if is(unit = "h")  then val * 3600
    else if is(unit = "d")  then val * 86400
    else if is(unit = "y")  then val * 31557600
    else false
)$ */

