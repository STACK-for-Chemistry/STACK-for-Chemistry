/* ---- Internal helpers ---- */

/* nuc_get_entry: Return the raw entry for a given nuclide ID string.
   Returns false if not found. */
/* nuc_get_entry(id) := block([result],
    result: false,
    for entry in %_NUCLIDE_DATA do (
        if is(entry[1] = id) then (
            result: entry,
            return(result)
        )
    ),
    result
)$ */

/* nuc_get_data: Return the data list for a given ID.
   Returns false if not found. */
/* nuc_get_data(id) := block([e],
    e: nuc_get_entry(id),
    if is(e = false) then false else e[2]
)$ */

