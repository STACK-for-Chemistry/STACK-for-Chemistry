/****************************************************************/
/*  Chemistry functions for STACK                               */
/*                                                              */
/*  V1.0 November 2025                                              */
/*                                                              */
/****************************************************************/

/****************************************************************/
/*                                                              */
/*  PSE Data Retrieving Functions                               */
/*                                                              */
/****************************************************************/

chem_internal_element_list_by_field(field_pos, field_value) := block([result, entry],
    result: [],
    for entry in %_CHEM_ELEMENTS do (
        if second(entry)[field_pos] = field_value then result: cons(first(entry), result)
    ),
    reverse(result)
)$

chem_internal_element_list_by_positive_field(field_pos) := block([result, entry],
    result: [],
    for entry in %_CHEM_ELEMENTS do (
        if second(entry)[field_pos] > 0 then result: cons(first(entry), result)
    ),
    reverse(result)
)$

chem_internal_element_by_two_fields(field_pos_1, field_value_1, field_pos_2, field_value_2) := block([i, n, entry, data, result],
    n: length(%_CHEM_ELEMENTS),
    result: false,
    for i:1 while is(result = false) thru n do (
        entry: %_CHEM_ELEMENTS[i],
        data: second(entry),
        if is(data[field_pos_1] = field_value_1) then (
            if is(data[field_pos_2] = field_value_2) then result: first(entry)
        )
    ),
    result
)$

chem_data_all(element) := block([entry, cdat, i],
    entry: assoc(element, %_CHEM_ELEMENTS),
    if is(entry=false) then return(false),
    cdat: [],
    for i:length(%_CHEM_FIELDS) step -1 thru 1 do (
        cdat: cons([%_CHEM_FIELDS[i], entry[i]], cdat)
    ),
    cdat
)$

/* This function returns the data "dp" associated with "element". */
chem_data(element, dp) := block([entry, idx],
    entry: assoc(element, %_CHEM_ELEMENTS),
    idx: assoc(dp, %_CHEM_FIELD_INDEX),
    if is(entry=false) or is(idx=false) then false else entry[idx]
)$

/* This function returns the element symbol for a given atomic number. */
chem_element(atomic_num) := block([entry],
    if not integerp(atomic_num) or atomic_num < 1 or atomic_num > length(%_CHEM_ELEMENTS) then return(false),
    entry: %_CHEM_ELEMENTS[atomic_num],
    if second(entry)[1] = atomic_num then first(entry) else false
)$

/* This function returns the data "dp" associated with "element", with units. */
chem_data_units(element, dp) := block([cunit, cdat],
    cdat: chem_data(element, dp),
    if is(cdat=false) then return(false),
    cunit: chem_units(dp),
    if is(cunit=null) then cdat else stackunits(cdat, cunit)
)$

/* This function returns the units addociated with field "dp". */
chem_units(dp) := assoc(dp, %_CHEM_FIELD_UNIT_DATA)$

/****************************************************************/
/*                                                              */
/*  PSE Navigation Functions                                    */
/*                                                              */
/****************************************************************/

/* This function returns an array of all element symbols. */
chem_element_array() := %_CHEM_ELEMENT_SYMBOLS$

/* This function returns an array of main group element symbols (MainGroup > 0). */
chem_element_array_maingroup() := chem_internal_element_list_by_positive_field(4)$

/* This function returns an array of element symbols for a given period. */
chem_element_period(period_num) := chem_internal_element_list_by_field(3, period_num)$

/* This function returns an array of element symbols for a given group number (IUPAC). */
chem_element_group(group_num) := chem_internal_element_list_by_field(5, group_num)$

/* This function returns an array of element symbols for a given main group number (1-8). */
chem_element_maingroup(maingroup_num) := chem_internal_element_list_by_field(4, maingroup_num)$

/* This function returns the element symbol for a given period and group number (IUPAC).
   Returns false if no such element exists. */
chem_element_period_group(period_num, group_num) := chem_internal_element_by_two_fields(3, period_num, 5, group_num)$

/* This function returns the element symbol for a given period and main group number.
   Returns false if no such element exists. */
chem_element_period_maingroup(period_num, maingroup_num) := chem_internal_element_by_two_fields(3, period_num, 4, maingroup_num)$

/****************************************************************/
/*                                                              */
/*  Electron Configuration Formatting                           */
/*                                                              */
/****************************************************************/

/* This function formats an electron configuration string for LaTeX display.
   Converts format like "[Kr] 5s2 4d10 5p6" to "[\mathrm{Kr}] 5\mathrm{s}^{2} 4\mathrm{d}^{10} 5\mathrm{p}^{6}"
   - Element symbols in brackets are wrapped in \mathrm{}
   - Orbital letters (s, p, d, f) are wrapped in \mathrm{}
   - Numbers after orbital letters become superscripts with ^{}
   - Spaces are added between orbital terms for better readability */
chem_electron_config_formatter(config_str) := block([chars, result, i, n, in_bracket, is_orbital, need_space],
    if sequal(config_str, "") then return(""),
    chars: charlist(config_str),
    n: length(chars),
    result: "",
    i: 1,
    in_bracket: false,
    need_space: false,
    
    while i <= n do (
        if sequal(chars[i], "[") then (
            result: sconcat(result, "[\\mathrm{"),
            in_bracket: true,
            need_space: false,
            i: i + 1
        ) else (
            if sequal(chars[i], "]") then (
                result: sconcat(result, "}]"),
                in_bracket: false,
                need_space: true,
                i: i + 1
            ) else (
                if sequal(chars[i], " ") then (
                    i: i + 1
                ) else (
                    is_orbital: (sequal(chars[i], "s") or sequal(chars[i], "p") or sequal(chars[i], "d") or sequal(chars[i], "f")) and not in_bracket,
                    if is_orbital then (
                        if need_space then (
                            result: sconcat(result, " ")
                        ),
                        result: sconcat(result, "\\mathrm{", chars[i], "}"),
                        need_space: false,
                        i: i + 1,
                        if i <= n then (
                            if cgreaterp(chars[i], "/") and clessp(chars[i], ":") then (
                                result: sconcat(result, "^{"),
                                while i <= n and cgreaterp(chars[i], "/") and clessp(chars[i], ":") do (
                                    result: sconcat(result, chars[i]),
                                    i: i + 1
                                ),
                                result: sconcat(result, "}"),
                                need_space: true
                            )
                        )
                    ) else (
                        result: sconcat(result, chars[i]),
                        i: i + 1
                    )
                )
            )
        )
    ),
    
    return(result)
)$

/* This function returns the formatted electron configuration for an element.
   Retrieves the configuration from the database and formats it for LaTeX display.
   Example: chem_electron_config("B") returns "[\mathrm{He}] 2\mathrm{s}^{2} 2\mathrm{p}^{1}" */
chem_electron_config(element) := block([config_str],
    config_str: chem_data(element, "ElectronConfiguration"),
    if is(config_str = false) then return(false),
    chem_electron_config_formatter(config_str)
)$

/****************************************************************/
/*                                                              */
/*  Molecule Molar Mass Calculation Functions                   */
/*                                                              */
/****************************************************************/

/* Manual digit-to-number conversion without forbidden functions
   Converts a string of digits to an integer using ASCII arithmetic */
chem_string_to_number(str) := block([chars, result, i, digit_val],
    if sequal(str, "") then return(0),
    chars: charlist(str),
    result: 0,
    for i:1 thru length(chars) do (
        /* Convert character '0'-'9' to number 0-9 using ASCII math */
        /* '0' is ASCII 48, '1' is 49, etc. */
        digit_val: cint(chars[i]) - 48,
        result: result * 10 + digit_val
    ),
    return(result)
)$

/* This function parses a chemical formula string and returns a list of [element, count] pairs.
   Example: chem_parse_formula("H2SO4") returns [["H", 2], ["S", 1], ["O"]] */
chem_parse_formula(formula) := block([chars, i, n, result, current_element, current_count, num_val],
    /* Parse directly in one pass; charge markers and other non-element tokens are skipped naturally. */
    chars: charlist(formula),
    n: length(chars),
    i: 1,
    result: [],
    
    while i <= n do (
        /* Check if current character is uppercase (start of element) */
        if cgreaterp(chars[i], "@") and clessp(chars[i], "[") then (
            current_element: chars[i],
            i: i + 1,
            
            /* Check for lowercase letter (second character of element symbol) */
            if i <= n and cgreaterp(chars[i], "`") and clessp(chars[i], "{") then (
                current_element: sconcat(current_element, chars[i]),
                i: i + 1
            ),
            
            /* Now check for number (count of atoms) */
            current_count: "",
            while i <= n and cgreaterp(chars[i], "/") and clessp(chars[i], ":") do (
                current_count: sconcat(current_count, chars[i]),
                i: i + 1
            ),
            
            /* If no number found, count is 1 */
            if sequal(current_count, "") then (
                num_val: 1
            ) else (
                /* Convert string to number using our helper function */
                num_val: chem_string_to_number(current_count)
            ),
            
            /* Prepend and reverse at the end for linear runtime. */
            result: cons([current_element, num_val], result)
        ) else (
            i: i + 1
        )
    ),
    
    return(reverse(result))
)$

/* This function calculates the molar mass of a molecule from its formula string with units.
   Example: chem_molar_mass("H2SO4") returns the molar mass with g/mol units */
chem_molar_mass(formula) := block([parsed, total_mass, elem_data],
    parsed: chem_parse_formula(formula),
    total_mass: 0,
    
    for pair in parsed do (
        elem_data: chem_data(first(pair), "AtomicMass"),
        if is(elem_data = false) then (
            /* Return false if element not found */
            return(false)
        ),
        total_mass: total_mass + elem_data * second(pair)
    ),
    
    return(stackunits(total_mass, g*mol^(-1)))
)$

/****************************************************************/
/*                                                              */
/*  Chemical Formula Display Function                           */
/*                                                              */
/****************************************************************/

/* This function wraps a chemical formula in \ce{} for LaTeX/mhchem rendering.
   Example: chem_display("H2SO4") returns "\\ce{H2SO4}" */
chem_display(substance) := sconcat("\\ce{", substance, "}")$

/****************************************************************/
/*                                                              */
/*  Chemical Constants                                          */
/*                                                              */
/****************************************************************/

%_CHEM_CONST_FIELDS : ["NA", "kB", "R", "F", "e", "h", "c", "P0", "T0", "Vm", "Vm_SATP", "u", "me", "mp", "mn", "eps0"]$

%_CHEM_CONST_VALUES : [
    6.02214076e23,      /* NA    - Avogadro's number */
    1.380649e-23,       /* kB   - Boltzmann constant */
    8.314462618,        /* R    - Universal gas constant */
    96485.33212,        /* F    - Faraday constant */
    1.602176634e-19,    /* e    - Elementary charge */
    6.62607015e-34,     /* h    - Planck constant */
    299792458,          /* c    - Speed of light */
    101325,             /* P0   - Standard pressure */
    273.15,             /* T0   - Standard temperature (0 degC) */
    22.414,             /* Vm   - Molar volume at STP */
    24.789,             /* Vm_SATP - Molar volume at SATP (25 degC, 1 bar) */
    1.66053906660e-27,  /* u    - Unified atomic mass unit */
    9.1093837015e-31,   /* me   - Electron mass */
    1.67262192369e-27,  /* mp   - Proton mass */
    1.67492749804e-27,  /* mn   - Neutron mass */
    8.8541878128e-12    /* eps0 - Permittivity of free space */
]$

%_CHEM_CONST_UNITS : [
    mol^(-1),           /* NA */
    J/K,                /* kB */
    J/(mol*K),          /* R */
    C/mol,              /* F */
    C,                  /* e */
    J*s,                /* h */
    m/s,                /* c */
    Pa,                 /* P0 */
    K,                  /* T0 */
    L/mol,              /* Vm */
    L/mol,              /* Vm_SATP */
    kg,                 /* u */
    kg,                 /* me */
    kg,                 /* mp */
    kg,                 /* mn */
    F/m                 /* eps0 */
]$

/* Returns only the numerical value of a constant.
   Example: chem_const_value("R") returns 8.314462618 */
chem_const_value(name) := assoc(name, %_CHEM_CONST_VALUE_DATA)$

/* Returns the constant as a stackunits object with its units.
   Example: chem_const_units("R") returns stackunits(8.314462618, J/(mol*K)) */
chem_const_units(name) := block([val, unt],
    val: assoc(name, %_CHEM_CONST_VALUE_DATA),
    unt: assoc(name, %_CHEM_CONST_UNIT_DATA),
    if is(val = false) then false else stackunits(val, unt)
)$

/* 
   This is the order of data below.  For efficiency, we don't store all the data as nested lists with repeaed fields.
   The functions above return formatted data for use with "assoc".
*/
%_CHEM_FIELDS : [
    "AtomicNumber", "Name", "Period", "MainGroup", "GroupNumber", "AtomicMass",
    "ElectronConfiguration", "Electronegativity", "AtomicRadius",
    "IonizationEnergy", "ElectronAffinity", "OxidationStates",
    "StandardState", "MeltingPoint", "BoilingPoint", "Density",
    "GroupBlock"
]$

%_CHEM_UNITS : [
    null, null, null, null, null, g*mol^(-1),
    null, null, pm,
    J, null, null,
    null, K, K, g/cm^3,
    null
]$

%_CHEM_FIELD_INDEX : [
    ["AtomicNumber", 1], ["Name", 2], ["Period", 3], ["MainGroup", 4], ["GroupNumber", 5], ["AtomicMass", 6],
    ["ElectronConfiguration", 7], ["Electronegativity", 8], ["AtomicRadius", 9],
    ["IonizationEnergy", 10], ["ElectronAffinity", 11], ["OxidationStates", 12],
    ["StandardState", 13], ["MeltingPoint", 14], ["BoilingPoint", 15], ["Density", 16],
    ["GroupBlock", 17]
]$

%_CHEM_FIELD_UNIT_DATA : zip_with("[", %_CHEM_FIELDS, %_CHEM_UNITS)$

%_CHEM_CONST_VALUE_DATA : zip_with("[", %_CHEM_CONST_FIELDS, %_CHEM_CONST_VALUES)$

%_CHEM_CONST_UNIT_DATA : zip_with("[", %_CHEM_CONST_FIELDS, %_CHEM_CONST_UNITS)$

