/****************************************************************/
/*                                                              */
/*  JSXGraph Plot Generation Functions                          */
/*                                                              */
/****************************************************************/

/* Generate complete JSXGraph JavaScript code for a titration curve
   Parameters:
     xdata: list of x values (volumes)
     ydata: list of y values (pH)
     v_max: maximum x-axis value
     v_pushoff: left boundary offset (typically negative, e.g., -v_equiv/20)
   Returns: JavaScript code string to be inserted with {# #} */
chem_jsxgraph_titration_code(xdata, ydata, v_max, v_pushoff) := block([code],
    code: sconcat(
        "var board = JXG.JSXGraph.initBoard(divid, {",
        "boundingbox: [", string(v_pushoff), ", 15, ", string(v_max), ", -1], ",
        "axis: true, ",
        "showCopyright: false, ",
        "defaultAxes: {",
        "x: {name: 'V(NaOH) / mL', withLabel: true, label: {position: 'rt', offset: [-30, -15]}}, ",
        "y: {name: 'pH', withLabel: true, label: {position: 'rt', offset: [5, 0]}}",
        "}",
        "});",
        "var xData = ", string(xdata), ";",
        "var yData = ", string(ydata), ";",
        "board.create('curve', [xData, yData], {strokeColor: 'blue', strokeWidth: 2});",
        "board.create('line', [[0, 7], [", string(v_max), ", 7]], {strokeColor: 'lightgray', strokeWidth: 1, dash: 3, straightFirst: false, straightLast: false});"
    ),
    code
)$

/* Extended version with equivalence points and pKa lines */
chem_jsxgraph_titration_code_full(xdata, ydata, v_max, v_pushoff, equiv_points, pKa_list) := block(
    [code, i, ep, pka],
    
    /* Base code with axis labels */
    code: sconcat(
        "var board = JXG.JSXGraph.initBoard(divid, {",
        "boundingbox: [", string(v_pushoff), ", 15, ", string(v_max), ", -1], ",
        "axis: true, ",
        "showCopyright: false, ",
        "defaultAxes: {",
        "x: {name: 'V(NaOH) / mL', withLabel: true, label: {position: 'rt', offset: [-30, -15]}}, ",
        "y: {name: 'pH', withLabel: true, label: {position: 'rt', offset: [5, 0]}}",
        "}",
        "});",
        "var xData = ", string(xdata), ";",
        "var yData = ", string(ydata), ";",
        "board.create('curve', [xData, yData], {strokeColor: 'blue', strokeWidth: 2});"
    ),
    
    /* Add pH 7 line */
    code: sconcat(code,
        "board.create('line', [[0, 7], [", string(v_max), ", 7]], ",
        "{strokeColor: 'lightgray', strokeWidth: 1, dash: 3, straightFirst: false, straightLast: false});"
    ),
    
    /* Add equivalence points */
    if listp(equiv_points) and length(equiv_points) > 0 then (
        for i: 1 thru length(equiv_points) do (
            ep: equiv_points[i],
            code: sconcat(code,
                "board.create('point', [", string(float(first(ep))), ", ", string(float(second(ep))), "], ",
                "{name: 'EP", string(i), "', size: 3, color: 'red', label: {offset: [10, 10], fontSize: 11}});"
            )
        )
    ),
    
    /* Add pKa lines */
    if listp(pKa_list) and length(pKa_list) > 0 then (
        for i: 1 thru length(pKa_list) do (
            pka: pKa_list[i],
            code: sconcat(code,
                "board.create('line', [[0, ", string(float(pka)), "], [", string(v_max), ", ", string(float(pka)), "]], ",
                "{strokeColor: 'gray', strokeWidth: 1, dash: 2, straightFirst: false, straightLast: false});",
                "board.create('text', [", string(v_max + 1), ", ", string(float(pka)), ", 'pKa", string(i), " = ", string(float(pka)), "'], {fontSize: 10, color: 'gray'});"
            )
        )
    ),
    
    code
)$

/* Convenience function: Generate everything from acid name
   Returns JavaScript code string for complete titration plot */
chem_jsxgraph_titration(acid, c_acid, c_base, v_acid, n_points, v_max) := block(
    [curve_data, xdata, ydata, pKa_list, equiv_vols, equiv_points, i, v_eq, pH_eq, v_pushoff],
    
    /* Generate curve data */
    curve_data: chem_titration_curve_data_vmax(acid, c_acid, c_base, v_acid, n_points, v_max),
    xdata: chem_titration_xdata(curve_data),
    ydata: chem_titration_ydata(curve_data),
    
    /* Get pKa values */
    pKa_list: chem_acidbase_pKa_list(acid),
    
    /* Calculate equivalence points */
    equiv_vols: chem_titration_equiv_volumes(acid, c_acid, c_base, v_acid),
    equiv_points: [],
    for i: 1 thru length(equiv_vols) do (
        v_eq: equiv_vols[i],
        pH_eq: chem_titration_pH(acid, c_acid, c_base, v_acid, v_eq),
        equiv_points: append(equiv_points, [[v_eq, pH_eq]])
    ),
    
    /* Calculate left boundary offset */
    if length(equiv_vols) > 0 then
        v_pushoff: -float(first(equiv_vols) / 20)
    else
        v_pushoff: -1,
    
    /* Generate code */
    chem_jsxgraph_titration_code_full(xdata, ydata, v_max, v_pushoff, equiv_points, pKa_list)
)$

/****************************************************************/
/*                                                              */
/*  JSXGraph Helper Functions                                   */
/*  Prepare all data needed for plotting in Question Text       */
/*                                                              */
/****************************************************************/

/* Calculate all data needed for a titration plot in one call.
   Returns a list that can be unpacked in Question Variables:
   [xdata, ydata, v_pushoff, equiv_points_list, pKa_list]
   
   Usage in Question Variables:
     plot_data: chem_titration_plot_data(acid, c_acid, c_base, v_acid, n_points, v_max);
     xdata: plot_data[1];
     ydata: plot_data[2];
     v_pushoff: plot_data[3];
     equiv_points: plot_data[4];
     pKa_list: plot_data[5];
*/
chem_titration_plot_data(acid, c_acid, c_base, v_acid, n_points, v_max) := block(
    [curve_data, xdata, ydata, pKa_list, equiv_vols, equiv_points, i, v_eq, pH_eq, v_pushoff],
    
    /* Generate curve data */
    curve_data: chem_titration_curve_data_vmax(acid, c_acid, c_base, v_acid, n_points, v_max),
    xdata: chem_titration_xdata(curve_data),
    ydata: chem_titration_ydata(curve_data),
    
    /* Get pKa values */
    pKa_list: chem_acidbase_pKa_list(acid),
    
    /* Calculate equivalence points as list of [v, pH] pairs */
    equiv_vols: chem_titration_equiv_volumes(acid, c_acid, c_base, v_acid),
    equiv_points: [],
    for i: 1 thru length(equiv_vols) do (
        v_eq: equiv_vols[i],
        pH_eq: chem_titration_pH(acid, c_acid, c_base, v_acid, v_eq),
        equiv_points: append(equiv_points, [[v_eq, pH_eq]])
    ),
    
    /* Calculate left boundary offset */
    if length(equiv_vols) > 0 then
        v_pushoff: float(-first(equiv_vols) / 20)
    else
        v_pushoff: -1.0,
    
    [xdata, ydata, v_pushoff, equiv_points, pKa_list]
)$

/* Get equivalence points as flat lists for easier JSXGraph use
   Returns [v_list, pH_list] where both are simple lists */
chem_titration_equiv_data(acid, c_acid, c_base, v_acid) := block(
    [equiv_vols, v_list, pH_list, i, v_eq, pH_eq],
    equiv_vols: chem_titration_equiv_volumes(acid, c_acid, c_base, v_acid),
    v_list: [],
    pH_list: [],
    for i: 1 thru length(equiv_vols) do (
        v_eq: equiv_vols[i],
        pH_eq: chem_titration_pH(acid, c_acid, c_base, v_acid, v_eq),
        v_list: append(v_list, [v_eq]),
        pH_list: append(pH_list, [pH_eq])
    ),
    [v_list, pH_list]
)$