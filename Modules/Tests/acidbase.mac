/****************************************************************/
/*                                                              */
/*  Titration Curve Functions for Polyprotic Acids              */
/*  Using Alpha Fractions and Charge Balance                    */
/*                                                              */
/****************************************************************/

/* Get all pKa values for a polyprotic acid as a list */
chem_acidbase_pKa_list(acid) := block([pKa_values, current_acid, current_pKa, current_base, max_iter],
    pKa_values: [],
    current_acid: acid,
    max_iter: 5,
    
    while max_iter > 0 and not is(current_acid = "") and not is(current_acid = null) do (
        current_pKa: chem_acidbase_pKa(current_acid),
        if is(current_pKa = null) then return(pKa_values),
        pKa_values: append(pKa_values, [current_pKa]),
        current_base: chem_acidbase_conjugate_base(current_acid),
        if is(current_base = "") or is(current_base = null) then return(pKa_values),
        current_acid: current_base,
        max_iter: max_iter - 1
    ),
    return(pKa_values)
)$

/* Convert pKa list to Ka list */
_pKa_to_Ka(pKa_list) := block([Ka_list, idx],
    Ka_list: [],
    idx: 1,
    while idx <= length(pKa_list) do (
        Ka_list: append(Ka_list, [float(10^(-pKa_list[idx]))]),
        idx: idx + 1
    ),
    return(Ka_list)
)$

/* Calculate alpha fractions - OPTIMIZED */
_alpha_fractions(H, Ka_list) := block([n, D, alphas, prod, idx, Hn],
    n: length(Ka_list),
    Hn: float(H^n),
    
    /* Build denominator */
    D: Hn,
    prod: 1.0,
    idx: 1,
    while idx <= n do (
        prod: prod * Ka_list[idx],
        D: D + prod * float(H^(n - idx)),
        idx: idx + 1
    ),
    
    if is(D < 1e-50) then D: 1e-50,
    
    /* Calculate alphas */
    alphas: [Hn / D],
    prod: 1.0,
    idx: 1,
    while idx <= n do (
        prod: prod * Ka_list[idx],
        alphas: append(alphas, [prod * float(H^(n - idx)) / D]),
        idx: idx + 1
    ),
    
    return(alphas)
)$

/* Charge balance equation - OPTIMIZED */
_charge_balance(H, CT, CB, Ka_list, Kw) := block([alphas, neg_charge, idx, n],
    alphas: _alpha_fractions(H, Ka_list),
    n: length(Ka_list),
    
    neg_charge: 0.0,
    idx: 1,
    while idx <= n do (
        neg_charge: neg_charge + idx * alphas[idx + 1],
        idx: idx + 1
    ),
    
    return(float(H + CB - Kw/H - CT * neg_charge))
)$

/* Solve for pH using bisection - 60 iterations for high precision */
_solve_pH(CT, CB, Ka_list) := block([Kw, H_lo, H_hi, H_mid, f_lo, f_hi, f_mid, iter],
    Kw: 1.0e-14,
    
    H_lo: 1e-14,
    H_hi: 1.0,
    
    f_lo: _charge_balance(H_lo, CT, CB, Ka_list, Kw),
    f_hi: _charge_balance(H_hi, CT, CB, Ka_list, Kw),
    
    /* 60 bisection iterations */
    iter: 0,
    while iter < 50 do (
        H_mid: float((H_lo + H_hi) / 2.0),
        f_mid: _charge_balance(H_mid, CT, CB, Ka_list, Kw),
        
        /* Use sign comparison that works reliably with floats */
        if is(f_lo > 0) = is(f_mid > 0) then (
            /* f_lo and f_mid have the same sign, root is in upper half */
            H_lo: H_mid,
            f_lo: f_mid
        ) else (
            /* f_lo and f_mid have opposite signs, root is in lower half */
            H_hi: H_mid,
            f_hi: f_mid
        ),
        
        iter: iter + 1
    ),
    
    return(float(-log(H_mid) / log(10)))
)$

/* Calculate pH at a given point during titration */
chem_titration_pH(acid, c_acid, c_base, v_acid, v_base) := block(
    [pKa_list, Ka_list, v_total, CT, CB, pH],
    
    pKa_list: chem_acidbase_pKa_list(acid),
    if is(length(pKa_list) = 0) then return(false),
    Ka_list: _pKa_to_Ka(pKa_list),
    
    v_total: float((v_acid + v_base) / 1000.0),
    CT: float((c_acid * v_acid / 1000.0) / v_total),
    CB: float((c_base * v_base / 1000.0) / v_total),
    
    pH: _solve_pH(CT, CB, Ka_list),
    
    if is(pH < 0) then pH: 0.0,
    if is(pH > 14) then pH: 14.0,
    
    return(pH)
)$

/* Generate titration curve data with automatic end volume */
chem_titration_curve_data(acid, c_acid, c_base, v_acid, n_points) := block(
    [num_protons, v_final_equiv, v_max, data, v, pH, idx, delta_v],
    
    num_protons: length(chem_acidbase_pKa_list(acid)),
    if is(num_protons = 0) then num_protons: 1,
    
    v_final_equiv: float((num_protons * c_acid * v_acid) / c_base),
    v_max: float(v_final_equiv * 1.3),
    delta_v: float(v_max / (n_points - 1)),
    
    data: [],
    idx: 0,
    
    while idx < n_points do (
        v: float(idx * delta_v),
        pH: chem_titration_pH(acid, c_acid, c_base, v_acid, v),
        if not is(pH = false) then data: append(data, [[v, pH]]),
        idx: idx + 1
    ),
    
    return(data)
)$

/* Generate titration curve data with custom end volume
   v_max: maximum volume to plot (mL) - if 0 or negative, uses automatic calculation */
chem_titration_curve_data_vmax(acid, c_acid, c_base, v_acid, n_points, v_max) := block(
    [num_protons, v_final_equiv, v_end, data, v, pH, idx, delta_v],
    
    num_protons: length(chem_acidbase_pKa_list(acid)),
    if is(num_protons = 0) then num_protons: 1,
    
    /* Use custom v_max if positive, otherwise calculate automatically */
    if is(v_max > 0) then (
        v_end: float(v_max)
    ) else (
        v_final_equiv: float((num_protons * c_acid * v_acid) / c_base),
        v_end: float(v_final_equiv * 1.3)
    ),
    
    delta_v: float(v_end / (n_points - 1)),
    
    data: [],
    idx: 0,
    
    while idx < n_points do (
        v: float(idx * delta_v),
        pH: chem_titration_pH(acid, c_acid, c_base, v_acid, v),
        if not is(pH = false) then data: append(data, [[v, pH]]),
        idx: idx + 1
    ),
    
    return(data)
)$

/* Convert titration data to JSXGraph-compatible JavaScript array string 
   Rounds values to 3 decimal places for cleaner output */
chem_titration_jsxgraph_points(data) := block([result, idx, pair, vv, pp],
    result: "[",
    idx: 1,
    while idx <= length(data) do (
        pair: data[idx],
        /* Round to 3 decimal places */
        vv: float(round(1000 * first(pair)) / 1000),
        pp: float(round(1000 * second(pair)) / 1000),
        result: sconcat(result, "[", string(vv), ",", string(pp), "]"),
        if is(idx < length(data)) then result: sconcat(result, ","),
        idx: idx + 1
    ),
    result: sconcat(result, "]"),
    return(result)
)$

/* NEW: Return X-values as a Maxima list (not a string) for direct JSXGraph use */
chem_titration_xdata(data) := block([result, idx],
    result: [],
    idx: 1,
    while idx <= length(data) do (
        result: append(result, [float(round(1000 * first(data[idx])) / 1000)]),
        idx: idx + 1
    ),
    return(result)
)$

/* NEW: Return Y-values (pH) as a Maxima list (not a string) for direct JSXGraph use */
chem_titration_ydata(data) := block([result, idx],
    result: [],
    idx: 1,
    while idx <= length(data) do (
        result: append(result, [float(round(1000 * second(data[idx])) / 1000)]),
        idx: idx + 1
    ),
    return(result)
)$

/* Get the i-th equivalence point volume (in mL) */
chem_titration_equiv_volume(c_acid, c_base, v_acid, i) := block([],
    if not integerp(i) then i: 1,
    if is(i < 1) then i: 1,
    float((i * c_acid * v_acid) / c_base)
)$

/* Get the pH at the i-th equivalence point */
chem_titration_equiv_pH(acid, c_acid, c_base, v_acid, i) := block([v_equiv],
    if not integerp(i) then i: 1,
    v_equiv: chem_titration_equiv_volume(c_acid, c_base, v_acid, i),
    chem_titration_pH(acid, c_acid, c_base, v_acid, v_equiv)
)$

/* Get the pH at the i-th half-equivalence point */
chem_titration_half_equiv_pH(acid, c_acid, c_base, v_acid, i) := block([v_half, prev_equiv],
    if not integerp(i) then i: 1,
    if is(i < 1) then i: 1,
    
    if is(i = 1) then (
        prev_equiv: 0
    ) else (
        prev_equiv: chem_titration_equiv_volume(c_acid, c_base, v_acid, i - 1)
    ),
    v_half: (prev_equiv + chem_titration_equiv_volume(c_acid, c_base, v_acid, i)) / 2,
    chem_titration_pH(acid, c_acid, c_base, v_acid, v_half)
)$

/* Get list of all equivalence volumes for a polyprotic acid (in mL) */
chem_titration_equiv_volumes(acid, c_acid, c_base, v_acid) := block([num_protons, volumes, idx],
    num_protons: length(chem_acidbase_pKa_list(acid)),
    if is(num_protons = 0) then return([]),
    
    volumes: [],
    idx: 1,
    while idx <= num_protons do (
        volumes: append(volumes, [chem_titration_equiv_volume(c_acid, c_base, v_acid, idx)]),
        idx: idx + 1
    ),
    return(volumes)
)$

/* Get list of all pKa values for plotting reference lines */
chem_titration_pKa_values(acid) := chem_acidbase_pKa_list(acid)$

/* Get the number of protons for an acid */
chem_acidbase_num_protons(acid) := block([nH],
    nH: chem_acidbase_nH(acid),
    if is(nH = null) then 1 else nH
)$

